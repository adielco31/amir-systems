---
import business from '../data/business.js'

const navLinks = [
  { href: '/',                                       label: 'בית' },
  { href: '/services/multimedia/android-screens/',   label: 'מולטימדיה' },
  { href: '/services/electrical/',                   label: 'חשמלאות' },
  { href: '/services/towing-hitch/',                 label: 'ווי גרירה' },
  { href: '/areas/afula/',                           label: 'אזורי שירות' },
  { href: '/about/',                                 label: 'אודות' },
]
---

<header class="sticky top-0 z-40 bg-[#040912]/92 backdrop-blur-xl border-b border-white/[0.07]">

  <!-- Main row -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-[68px] gap-4">

      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0 group">
        <img
          src="/logo.png"
          alt={business.name}
          class="h-12 md:h-14 w-auto object-contain brightness-110 group-hover:brightness-125 transition-all duration-300"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-0.5 flex-1 justify-center">
        {navLinks.map(item => (
          <a
            href={item.href}
            class="relative px-3.5 py-2 text-sm font-medium text-gray-400 hover:text-white rounded-lg transition-colors duration-200 hover:bg-white/[0.06] group"
          >
            {item.label}
            <span class="absolute bottom-0 right-3 left-3 h-px bg-brand-500 scale-x-0 group-hover:scale-x-100 transition-transform duration-200 origin-right" />
          </a>
        ))}
      </nav>

      <!-- CTA buttons + hamburger -->
      <div class="flex items-center gap-2 flex-shrink-0">
        <a
          href={`tel:${business.phoneClean}`}
          class="hidden sm:inline-flex items-center gap-2 px-4 py-2.5 bg-brand-700 hover:bg-brand-600 text-white font-semibold rounded-xl transition-all text-sm shadow-sm hover:shadow-[0_0_18px_rgba(29,78,216,0.5)] btn-shine"
        >
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span class="ltr">{business.phone}</span>
        </a>

        <a
          href={`https://wa.me/${business.whatsapp}?text=${encodeURIComponent('שלום, הגעתי מהאתר')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-green-600 hover:bg-green-500 text-white font-semibold rounded-xl transition-all text-sm btn-shine hover:shadow-[0_0_18px_rgba(34,197,94,0.4)]"
        >
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24z"/>
          </svg>
          <span class="hidden sm:inline">וואטסאפ</span>
        </a>

        <!-- Hamburger -->
        <button
          id="mobile-toggle"
          aria-label="פתח תפריט"
          aria-expanded="false"
          class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl border border-white/[0.1] hover:bg-white/[0.07] text-gray-400 hover:text-white transition-colors"
        >
          <svg id="icon-menu" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/>
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-nav" class="hidden lg:hidden border-t border-white/[0.07] bg-[#040912]">
    <div class="max-w-7xl mx-auto px-4 py-3">
      <nav class="flex flex-col gap-0.5 mb-3">
        {[...navLinks, { href: '/contact/', label: 'יצירת קשר' }].map(item => (
          <a
            href={item.href}
            class="px-4 py-3 text-gray-300 hover:text-white hover:bg-white/[0.06] rounded-xl font-medium text-sm transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>
      <div class="pt-3 border-t border-white/[0.06]">
        <a
          href={`tel:${business.phoneClean}`}
          class="flex items-center justify-center gap-2 w-full py-3 bg-brand-700 hover:bg-brand-600 text-white font-bold rounded-xl transition-colors text-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          התקשרו: <span class="ltr">{business.phone}</span>
        </a>
      </div>
    </div>
  </div>

</header>

<script>
  const toggle   = document.getElementById('mobile-toggle')
  const menu     = document.getElementById('mobile-nav')
  const iconMenu  = document.getElementById('icon-menu')
  const iconClose = document.getElementById('icon-close')

  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false
    toggle.setAttribute('aria-expanded', String(open))
    iconMenu?.classList.toggle('hidden', open)
    iconClose?.classList.toggle('hidden', !open)
  })
</script>
