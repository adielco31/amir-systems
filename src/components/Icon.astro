interface Props {
  name: string
  class?: string
  strokeWidth?: number
}

const { name, class: className = 'w-6 h-6', strokeWidth = 2 } = Astro.props as Props
const paths = svgPaths[name] ?? svgPaths.zap
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={paths}
/>
