---
import BaseLayout from '../../layouts/BaseLayout.astro'
import FAQ from '../../components/FAQ.astro'
import CTABanner from '../../components/CTABanner.astro'
import business from '../../data/business.js'
import Icon from '../../components/Icon.astro'

const title = 'מכונאות רכב בעפולה | טיפולים, בלמים ומתלים'
const description = 'שירותי מכונאות כללית לרכב — טיפולים תקופתיים, בלמים, מתלים, החלפת שמן ורצועות. שירות משולב עם חשמלאות לפתרון מקיף. בעפולה והאזור.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'מכונאות כללית לרכב',
  provider: { '@id': `${business.url}#business` },
  areaServed: ['עפולה','מגדל העמק','נוף הגליל','יקנעם','טבריה','בית שאן','מגידו','נצרת'].map(a => ({ '@type': 'City', name: a })),
}

const faqs = [
  {
    q: 'אילו שירותי מכונאות אתם מבצעים?',
    a: 'אנחנו מבצעים טיפולים תקופתיים (שמן, פילטרים), בלמים (רפידות ודיסקיות), מתלים (בולמי זעזועים, קפיצים, בני כדור), מרצלות הגה, רצועות (distribution, serpentine), ותיקון דליפות שמן ונוזלים. בנוסף, השילוב עם יכולות הדיאגנוסטיקה שלנו אומר שבעיות שמתחילות כ"רעש מוזר" ומסתיימות בקוד תקלה — מטופלות במקום אחד.',
  },
  {
    q: 'כמה עולה טיפול שנתי אצלכם?',
    a: 'טיפול שנתי בסיסי (שמן + פילטרים) מתחיל ב-200-350 ₪, תלוי בסוג השמן ובמספר הפילטרים לרכב הספציפי. שמן סינתטי 5W-30 ל-5 ליטר + פילטר שמן + פילטר אוויר = מחיר שקוף שתדעו מראש. טיפול מורחב עם בדיקת מתלים, בלמים ונוזלים — כ-400-600 ₪ תלוי בממצאים.',
  },
  {
    q: 'מה היתרון בסדנה שמשלבת מכונאות וחשמלאות?',
    a: 'רוב הבעיות ברכב המודרני אינן "טהורות" — בעיה מכנית מדווחת על ידי חיישן חשמלי, ובעיה חשמלית מתגלה תוך כדי עבודה מכנית. כשמכונאי ממוחשב ברמה שלנו עובד על הרכב, הוא מחובר לציוד דיאגנוסטיקה כל הזמן — ולא מחמיץ תקלות נלוות. בסדנאות שמתמחות רק במכניקה או רק בחשמל, לקוחות מגיעים פעמיים.',
  },
  {
    q: 'האם אתם עושים טיפולים לכל הדגמים?',
    a: 'רוב דגמי הרכב הנפוצים בישראל — יונדאי, קיה, טויוטה, מאזדה, פורד, ניסן, שברולט, סוזוקי ועוד. לרכבים גרמניים יוקרתיים (BMW, Mercedes, Audi S-line ומעלה) נעריך עם הרכב לפנינו. ביקשנו תמיד אם יש ספק.',
  },
  {
    q: 'איך יודעים מתי לבצע טיפול?',
    a: 'כלל האצבע: כל 10,000-15,000 ק"מ לשמן (לפי יצרן), פעם בשנה לטיפול בסיסי, וכל 30,000-40,000 ק"מ לבדיקת מתלים ובלמים. לרכבים ישנים יותר — כל 7,500-10,000 ק"מ. לא בטוחים? בדיקת בלמים ומתלים בחינם כשמגיעים לשירות אחר.',
  },
]
---
<BaseLayout title={title} description={description} schema={schema}>
  <nav class="breadcrumb-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-gray-400">
      <a href="/" class="hover:text-white">בית</a><span class="mx-2">›</span>
      <a href="/services/" class="hover:text-white">שירותים</a><span class="mx-2">›</span>
      <span class="text-white font-medium">מכונאות כללית</span>
    </div>
  </nav>

  <section class="relative bg-[#040912] text-white py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0 tech-grid opacity-30 pointer-events-none" />
    <div class="absolute inset-0 pointer-events-none hero-radial" />
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        מכונאות רכב בעפולה<br/>
        <span class="text-accent-500">משולב עם דיאגנוסטיקה מקצועית</span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        טיפולים תקופתיים, בלמים, מתלים ורצועות — בסדנה שמשלבת מכונאות
        עם חשמלאות ודיאגנוסטיקה ברמה גבוהה.
      </p>
    </div>
  </section>

  <article class="py-12 md:py-16 bg-[#060d1e]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 prose-content">

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">מכונאות שמבינה גם את החשמל</h2>
        <p class="text-gray-300 leading-relaxed text-lg mb-4">
          הרכב המודרני הוא שילוב של מכניקה ואלקטרוניקה. בלמים שמשמיעים קול מוזר עלולים
          להיות הנורת ABS שמדווחת על חיישן כושל. מנוע שנוסע גרוע עשוי להיות בעיית
          מצית ולא בעיית מנוע מכנית. כשאנחנו עובדים על הרכב שלכם, ציוד הדיאגנוסטיקה
          מחובר בכל זמן — כך שכל בעיה, גם כזו שלא חשבתם להגיד עליה, עולה לפני השטח.
        </p>
        <p class="text-gray-300 leading-relaxed text-lg">
          ב<strong>אמיר מערכות</strong>, מכונאות כללית היא חלק טבעי מהשירות שאנחנו נותנים
          כבר {business.stats.yearsOfExperience}+ שנים. לקוחות שמגיעים לשדרוג מסך לפעמים
          יוצאים גם עם טיפול שמן שאיחרו בו — כי אנחנו שמנו לב לנורית התחזוקה.
          כי שירות שלם אומר שרואים את כל הרכב.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">השירותים המכניים שלנו</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            { icon: 'droplets', t: 'החלפת שמן ופילטרים', d: 'שמן מנוע, פילטר שמן, פילטר אוויר, פילטר מזגן — טיפול שנתי בסיסי.' },
            { icon: 'shield', t: 'מערכת בלמים', d: 'רפידות, דיסקיות, בודקים גם בלמי חניה וצינורות בלמים.' },
            { icon: 'wrench', t: 'מתלים ופסים', d: 'בולמי זעזועים, קפיצים, בני כדור, מרצלות הגה — בדיקה ותיקון.' },
            { icon: 'settings', t: 'רצועות ושרשראות', d: 'רצועת תזמון/שרשרת, רצועה סרפנטינית, גלגלות מתח.' },
            { icon: 'droplets', t: 'דליפות ונוזלים', d: 'איתור דליפות שמן, קירור, הגה הידראולי, גיר — לפני שמחמירים.' },
            { icon: 'search', t: 'בדיקה לפני קנייה', d: 'קונים רכב יד שנייה? בדיקה מכנית + דיאגנוסטיקה מלאה לפני הסגירה.' },
          ].map(s => (
            <div class="p-5 glass-card">
              <div class="w-11 h-11 bg-brand-500/15 text-brand-400 rounded-xl flex items-center justify-center mb-3"><Icon name={s} class="w-5 h-5" /></div>
              <h3 class="font-bold text-white mb-2">{s.t}</h3>
              <p class="text-sm text-gray-400">{s.d}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">שירותים קשורים</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <a href="/services/electrical/" class="block p-5 bg-white/[0.04] border border-white/[0.09] rounded-lg hover:border-brand-500/40 hover:bg-white/[0.07] transition-all backdrop-blur-sm">
            <h3 class="font-bold text-white mb-2">חשמלאי רכב</h3>
            <p class="text-sm text-gray-400">בשילוב עם מכונאות — פתרון מלא.</p>
          </a>
          <a href="/services/ecu-reset/" class="block p-5 bg-white/[0.04] border border-white/[0.09] rounded-lg hover:border-brand-500/40 hover:bg-white/[0.07] transition-all backdrop-blur-sm">
            <h3 class="font-bold text-white mb-2">איפוס מחשב</h3>
            <p class="text-sm text-gray-400">לאחר כל תיקון — מחיקת קודים ואיפוס.</p>
          </a>
          <a href="/services/ac-repair/" class="block p-5 bg-white/[0.04] border border-white/[0.09] rounded-lg hover:border-brand-500/40 hover:bg-white/[0.07] transition-all backdrop-blur-sm">
            <h3 class="font-bold text-white mb-2">מיזוג רכב</h3>
            <p class="text-sm text-gray-400">כולל חגורת קומפרסור ומצמד — עבודה מכנית.</p>
          </a>
        </div>
      </section>
    </div>
  </article>

  <FAQ items={faqs} title="שאלות נפוצות על מכונאות רכב" />
  <CTABanner title="הרכב צריך טיפול?" subtitle="ייעוץ חינמי — בסדנה שרואה את כל הרכב, לא רק חלק ממנו" />
</BaseLayout>
