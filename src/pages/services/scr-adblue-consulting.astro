---
import BaseLayout from '../../layouts/BaseLayout.astro'
import FAQ from '../../components/FAQ.astro'
import CTABanner from '../../components/CTABanner.astro'
import business from '../../data/business.js'
import Icon from '../../components/Icon.astro'

const title = 'אבחון תקלות SCR ו-AdBlue | ייעוץ ופתרונות'
const description = 'אבחון תקלות מערכת SCR ו-AdBlue ברכבי דיזל — נורית AdBlue, מד מילוי, מערכת הזרקה ואיכות נוזל. ייעוץ ופתרונות מותאמים אישית בעפולה והאזור.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'אבחון תקלות SCR ו-AdBlue',
  provider: { '@id': `${business.url}#business` },
  areaServed: ['עפולה','מגדל העמק','נוף הגליל','יקנעם','טבריה','בית שאן','מגידו','נצרת'].map(a => ({ '@type': 'City', name: a })),
}

const faqs = [
  {
    q: 'מה זה AdBlue ולמה יש תקלות?',
    a: 'AdBlue (נוזל DEF) הוא נוזל אוריאה שמוזרק למערכת SCR (Selective Catalytic Reduction) ברכבי דיזל Euro 6 כדי להפחית פליטות NOx. הרכב מנטר את רמת הנוזל, את איכותו ואת תקינות מערכת ההזרקה. תקלות נפוצות: נוזל שנגמר, נוזל דלוח (מים במיכל), נסיור AdBlue תקול, חיישן רמה כושל, או מזריק שנסתם. כל אחד מאלו מדליק נורית ויכול להוביל לנעילת מנוע.',
  },
  {
    q: 'הנורה של AdBlue נדלקה — מה לעשות?',
    a: 'אם נורת ה-AdBlue נדלקה, הרכב מציג בדרך כלל ספירה לאחור — לרוב 1,000-2,400 ק"מ לפני שנועל את המנוע. בשלב ראשון, בדקו ומלאו את מיכל ה-AdBlue (אם מתחת לחצי). אם הנורה נשארת לאחר מילוי, זה מצביע על בעיה אחרת — איכות הנוזל, חיישן או מערכת ההזרקה — שדורשת אבחון מקצועי.',
  },
  {
    q: 'האם ניתן לנסוע עם נורת AdBlue דולקת?',
    a: 'לזמן מוגבל בלבד. כשהמיכל מגיע לאפס — הרכב מגביל הפעלה. לאחר כמה הפעלות מוגבלות, הוא עלול לנעול ולא לאפשר התנעה עד שמיכל ה-AdBlue מתמלא ומאופס בציוד דיאגנוסטיקה. עדיף לא להגיע לנקודה הזו.',
  },
  {
    q: 'מה גורם לנורת "Bad AdBlue Quality"?',
    a: 'נורת איכות AdBlue מצביעה לרוב על: מילוי עם נוזל לא סטנדרטי (לא AdBlue מאושר ISO 22241), מים שנכנסו למיכל, או חיישן איכות (NOx sensor) כושל. מילוי עם AdBlue מאושר ומנקה הפותר את הבעיה ברוב המקרים. אם הנורה חוזרת — סימן לחיישן פגום שדורש בדיקה.',
  },
  {
    q: 'כמה עולה אבחון ותיקון תקלת AdBlue?',
    a: 'אבחון מלא של מערכת SCR/AdBlue הוא חלק מהשירות שלנו. מחיר התיקון תלוי בממצאים: החלפת חיישן NOx, תיקון מזריק, או ניקוי מערכת — כל אחד עולה אחרת. אנחנו מציגים את הממצאים ועלות הפתרון לפני שמתחילים.',
  },
  {
    q: 'האם יש פתרונות חלופיים לרכב שמתקלקל כל הזמן?',
    a: 'ישנם מקרים בהם מערכת SCR גורמת לבעיות חוזרות — חיישנים כושלים, מזריקים שנסתמים, ועלויות תחזוקה גבוהות. אנחנו מציעים ייעוץ מקצועי לגבי האפשרויות הקיימות לרכב הספציפי שלכם — כולל הסברה על ההשלכות הטכניות, הביטוחיות והחוקיות של כל בחירה. ההחלטה היא שלכם, אנחנו נספק את המידע.',
  },
]
---
<BaseLayout title={title} description={description} schema={schema}>
  <nav class="breadcrumb-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-gray-400">
      <a href="/" class="hover:text-white">בית</a><span class="mx-2">›</span>
      <a href="/services/" class="hover:text-white">שירותים</a><span class="mx-2">›</span>
      <span class="text-white font-medium">ייעוץ SCR / AdBlue</span>
    </div>
  </nav>

  <section class="relative bg-[#040912] text-white py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0 tech-grid opacity-30 pointer-events-none" />
    <div class="absolute inset-0 pointer-events-none hero-radial" />
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        אבחון תקלות SCR ו-AdBlue<br/>
        <span class="text-accent-500">ייעוץ ופתרונות מותאמים</span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        נורית AdBlue דולקת? מד מילוי לא מדויק? מערכת SCR שמתקלקלת?
        אבחון ממוחשב מלא וייעוץ מקצועי — לפני כל החלטה.
      </p>
    </div>
  </section>

  <article class="py-12 md:py-16 bg-[#060d1e]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 prose-content">

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">מערכת SCR / AdBlue — מה היא ולמה היא גורמת לבעיות</h2>
        <p class="text-gray-300 leading-relaxed text-lg mb-4">
          מערכת SCR (Selective Catalytic Reduction) היא רכיב חובה ברכבי דיזל Euro 6 מ-2015
          ואילך. היא מפחיתה פליטות חנקן על ידי הזרקת נוזל AdBlue (אוריאה מדוללת) לגזי
          הפליטה לפני הקטליזטור. כשהמערכת עובדת — היא שקופה לחלוטין. כשמשהו כושל — מקבלים
          נוריות, הגבלות ובמקרי קיצון נעילת מנוע.
        </p>
        <p class="text-gray-300 leading-relaxed text-lg">
          ב<strong>אמיר מערכות</strong>, אנחנו מאבחנים תקלות SCR/AdBlue בציוד מקצועי שקורא
          את כל מערכות הדיזל בפירוט. לאחר האבחון נסביר בדיוק מה הבעיה, מה האפשרויות,
          ומה ההשלכות של כל בחירה — כדי שתקבלו החלטה מושכלת.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">תקלות SCR/AdBlue שאנחנו מאבחנים</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            { icon: 'droplets', t: 'מיכל AdBlue ריק / רמה נמוכה', d: 'בדיקת מד הרמה, מילוי ואיפוס הספירה לאחור בציוד דיאגנוסטיקה.' },
            { icon: 'cpu', t: 'תקלת איכות נוזל', d: 'חיישן NOx שמזהה אוריאה לא סטנדרטית — בדיקה, ניקוי מיכל, ואיפוס.' },
            { icon: 'droplets', t: 'מזריק AdBlue תקול', d: 'מזריק שנסתם או נכשל — בדיקה, ניקוי או החלפה.' },
            { icon: 'target', t: 'חיישני NOx / SCR', d: 'חיישני NOx לפני ואחרי הקטליזטור — החלפה ואיפוס.' },
            { icon: 'plug', t: 'משאבת AdBlue', d: 'בדיקת פעולת המשאבה ולחץ הזרקה.' },
            { icon: 'cpu', t: 'מחיקת קודים ואיפוס', d: 'לאחר תיקון — מחיקה ואימות שהמערכת חזרה לפעולה תקינה.' },
          ].map(s => (
            <div class="p-5 glass-card">
              <div class="w-11 h-11 bg-brand-500/15 text-brand-400 rounded-xl flex items-center justify-center mb-3"><Icon name={s} class="w-5 h-5" /></div>
              <h3 class="font-bold text-white mb-2">{s.t}</h3>
              <p class="text-sm text-gray-400">{s.d}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-12 p-6 glass-section">
        <h2 class="text-xl md:text-2xl font-bold text-white mb-4">הגישה שלנו: מידע מלא לפני כל החלטה</h2>
        <p class="text-gray-300 leading-relaxed mb-4">
          לקוחות שמגיעים עם בעיות AdBlue חוזרות לעיתים שואלים על כל האפשרויות הקיימות.
          אנחנו מאמינים שהלקוח זכאי למידע מלא — כולל הסברה על ההשלכות הטכניות, הביטוחיות
          והחוקיות של כל אפשרות — כדי שיוכל לקבל החלטה מושכלת עבור הצורך שלו.
        </p>
        <p class="text-gray-500 leading-relaxed text-sm">
          שימו לב: שינויים במערכות פליטה כפופים לתקנות אירופאיות ולחוק ישראלי. נסיעה עם
          מערכת פליטה שעברה שינוי לא מאושר עלולה לגרור בעיות במבחן רישוי ובביטוח.
          אנחנו מספקים ייעוץ מלא לגבי ההשלכות — ההחלטה היא שלכם.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">שירותים קשורים</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <a href="/services/ecu-reset/" class="block p-5 bg-white/[0.04] border border-white/[0.09] rounded-lg hover:border-brand-500/40 hover:bg-white/[0.07] transition-all backdrop-blur-sm">
            <h3 class="font-bold text-white mb-2">איפוס מחשב מנוע</h3>
            <p class="text-sm text-gray-400">מחיקת קודים ואיפוס לאחר תיקון.</p>
          </a>
          <a href="/services/electrical/" class="block p-5 bg-white/[0.04] border border-white/[0.09] rounded-lg hover:border-brand-500/40 hover:bg-white/[0.07] transition-all backdrop-blur-sm">
            <h3 class="font-bold text-white mb-2">דיאגנוסטיקה מלאה</h3>
            <p class="text-sm text-gray-400">בדיקת כל מערכות הרכב לצד בדיקת ה-SCR.</p>
          </a>
          <a href="/services/general-mechanics/" class="block p-5 bg-white/[0.04] border border-white/[0.09] rounded-lg hover:border-brand-500/40 hover:bg-white/[0.07] transition-all backdrop-blur-sm">
            <h3 class="font-bold text-white mb-2">מכונאות כללית</h3>
            <p class="text-sm text-gray-400">בדיקת מצב כללי של הרכב לצד אבחון SCR.</p>
          </a>
        </div>
      </section>
    </div>
  </article>

  <FAQ items={faqs} title="שאלות נפוצות על תקלות SCR ו-AdBlue" />
  <CTABanner title="בעיית AdBlue? מגיעים לאבחון" subtitle="ייעוץ מלא, שקיפות מלאה — לפני כל החלטה" />
</BaseLayout>
