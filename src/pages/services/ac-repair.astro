---
import BaseLayout from '../../layouts/BaseLayout.astro'
import FAQ from '../../components/FAQ.astro'
import CTABanner from '../../components/CTABanner.astro'
import business from '../../data/business.js'

const title = 'תיקון מיזוג אוויר לרכב | מילוי גז ואיתור דליפות'
const description = 'תיקון מיזוג אוויר לרכב — מילוי גז, החלפת קומפרסור, איתור דליפות, ניקוי מערכת. שירות מהיר ומקצועי בעפולה והאזור, אחריות מלאה.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'תיקון מיזוג אוויר לרכב',
  provider: { '@id': `${business.url}#business` },
  areaServed: ['עפולה','מגדל העמק','נוף הגליל','יקנעם','טבריה','בית שאן','מגידו','נצרת'].map(a => ({ '@type': 'City', name: a })),
}

const faqs = [
  {
    q: 'המיזוג לא מקרר — מה הסיבה הנפוצה ביותר?',
    a: 'הסיבה הנפוצה ביותר היא מחסור בגז קירור (פריאון) — בדרך כלל בגלל דליפה קטנה שמתפתחת עם הזמן בצינורות, חיבורים או הקומפרסור. תחושת ה"גז ירד" מופיעה לרוב אחרי 4-7 שנים. כסיבה שנייה: קומפרסור שנכשל, בלגן בחגורת ההינע, או מפסק לחץ שחסם את המערכת. האבחון מתחיל בבדיקת לחץ הגז ואחריה בדיקת הרכיבים.',
  },
  {
    q: 'כמה עולה מילוי גז למיזוג רכב?',
    a: 'מילוי גז בסיסי (R134a או R1234yf ברכבים חדשים) עולה בין 250 ל-500 ₪, תלוי בסוג הגז ובכמות הנדרשת. בגז R1234yf (רכבים מ-2017 ומעלה) המחיר גבוה יותר כי הגז עצמו יקר. חשוב: מילוי בלבד בלי לאתר ולתקן את הדליפה — הגז יאזל שוב תוך חודשים. אנחנו מאתרים את הדליפה לפני שממלאים.',
  },
  {
    q: 'מה זה "שמן קומפרסור" ולמה חשוב להוסיף?',
    a: 'הקומפרסור דורש שמן סיכה מיוחד שמסתובב יחד עם הגז במעגל הקירור. כשממלאים גז בלי לבדוק את רמת השמן, הקומפרסור עלול להינזק — וזה תיקון של 1,500-4,000 ₪ שאפשר היה למנוע. אנחנו תמיד בודקים ומוסיפים שמן קומפרסור כחלק מתהליך מילוי הגז.',
  },
  {
    q: 'כמה זמן תיקון מיזוג לוקח?',
    a: 'מילוי גז לאחר איתור דליפה — 1-2 שעות. החלפת קומפרסור — 3-5 שעות, תלוי בנגישות ברכב. ניקוי מערכת אידוי — שעה. תיקון מורכב שכולל גם החלפת אבשורבר וניקוי מלא — חצי יום. מסבירים לפני ההתחלה.',
  },
  {
    q: 'האם כדאי לתקן מיזוג ברכב ישן?',
    a: 'ברוב המקרים — כן. עלות תיקון נפוצה (מילוי גז + איטום דליפה) היא 400-700 ₪, שזה זניח בהשוואה לנסיעה ישראלית בקיץ בלי מיזוג. גם קומפרסור חדש (1,500-3,000 ₪) לרוב שווה אם הרכב עצמו בסדר. אנחנו נגיד לכם בכנות אם התיקון לא כלכלי.',
  },
  {
    q: 'מה ההבדל בין גז R134a לגז R1234yf?',
    a: 'R134a הוא הגז הסטנדרטי שהיה בכל הרכבים עד 2017 בערך. R1234yf הוא הגז האירופי החדש שנדרש בתקנות פליטות חדשות — פחות מזיק לסביבה, אבל יקר פי 5-8. רכבים מ-2017 ומעלה (ובמיוחד אירופאים) מגיעים עם מערכת שמותאמת לR1234yf בלבד — לא ניתן לערבב בין הגזים. נבדוק לפני המילוי.',
  },
]
---
<BaseLayout title={title} description={description} schema={schema}>
  <nav class="bg-[#040912] border-b border-white/[0.07] py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-gray-400">
      <a href="/" class="hover:text-white">בית</a><span class="mx-2">›</span>
      <a href="/services/" class="hover:text-white">שירותים</a><span class="mx-2">›</span>
      <span class="text-white font-medium">מיזוג אוויר לרכב</span>
    </div>
  </nav>

  <section class="relative bg-[#040912] text-white py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0 tech-grid opacity-30 pointer-events-none" />
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(29,78,216,0.4) 0%, transparent 65%);" />
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        תיקון מיזוג אוויר לרכב<br/>
        <span class="text-accent-500">בעפולה והגלבוע</span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        מילוי גז, איתור ותיקון דליפות, החלפת קומפרסור וניקוי מערכת.
        שירות מהיר לפני הקיץ — אחריות מלאה.
      </p>
    </div>
  </section>

  <article class="py-12 md:py-16 bg-[#060d1e]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 prose-content">

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">מיזוג שלא מקרר — אל תחכו לאמצע הקיץ</h2>
        <p class="text-gray-300 leading-relaxed text-lg mb-4">
          קיץ ישראלי בלי מיזוג עובד הוא סיוט — במיוחד באזורים כמו עמק יזרעאל, בית שאן והגלבוע
          שמוכרים בחום כבד. בעיות מיזוג מתפתחות לאט — קצת פחות קר מהשנה שעברה, ואחרי
          כמה שנים המיזוג כמעט לא מרגיש. האבחון בדרך כלל מגלה בעיה פשוטה שאפשר לתקן תוך שעות.
        </p>
        <p class="text-gray-300 leading-relaxed text-lg">
          ב<strong>אמיר מערכות</strong>, אנחנו מאבחנים ומתקנים מיזוג רכב עם ציוד מקצועי —
          מכשיר רכיבה ייעודי לאיתור דליפות, מילוי גז בדיוק לפי מפרט, ובדיקה שהמערכת
          עובדת כראוי לפני שיוצאים. לא ממלאים גז ומשחררים מבלי לדעת שהבעיה נפתרה.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">שירותי מיזוג שאנחנו נותנים</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            { icon: '❄️', t: 'מילוי גז קירור', d: 'R134a ו-R1234yf — מילוי מדויק לפי מפרט הרכב, כולל תוספת שמן קומפרסור.' },
            { icon: '🔍', t: 'איתור ותיקון דליפות', d: 'זיהוי נקודת הדליפה בציוד UV ואיטום — הדרך היחידה שמחזיקה לאורך זמן.' },
            { icon: '⚙️', t: 'החלפת קומפרסור', d: 'קומפרסור שנכשל — פירוק, החלפה, שטיפת מעגל, ומילוי מחדש.' },
            { icon: '🌬️', t: 'ניקוי מערכת אידוי', d: 'ריח רע מהאוורור? ניקוי מקצועי של האידוי ועובש שנאגר עם הזמן.' },
            { icon: '🔧', t: 'חגורת קומפרסור ומצמד', d: 'החלפת חגורת הינע ומצמד קומפרסור — בעיה נפוצה שחוסמת את המיזוג.' },
            { icon: '📊', t: 'בדיקת לחץ ואבחון', d: 'חיבור מד לחץ דו-צדדי לאבחון מדויק של מצב המערכת לפני כל עבודה.' },
          ].map(s => (
            <div class="p-5 bg-white/[0.04] border border-white/[0.09] rounded-xl backdrop-blur-sm">
              <div class="text-2xl mb-2">{s.icon}</div>
              <h3 class="font-bold text-white mb-2">{s.t}</h3>
              <p class="text-sm text-gray-400">{s.d}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-12 p-6 bg-gray-50 rounded-xl">
        <h2 class="text-xl md:text-2xl font-bold text-white mb-4">חשוב: איתור דליפה לפני מילוי גז</h2>
        <p class="text-gray-300 leading-relaxed mb-4">
          מילוי גז בלי לאתר את הדליפה הוא פתרון זמני. הגז ייאזל שוב תוך שבועות עד חודשים,
          ואתם חוזרים לאותה נקודה עם כסף שנזרק. אנחנו <strong>לא ממלאים גז</strong> בלי לבדוק
          קודם שהמערכת אטומה — כי זה לא הגון ללקוח ולא מקצועי.
        </p>
        <p class="text-gray-300 leading-relaxed">
          אם קיבלתם בעבר מילוי גז שלא החזיק — כנראה שהדליפה לא טופלה. אצלנו, אם מוצאים דליפה
          ניתנת לאיטום, מטפלים בה לפני המילוי ומוודאים שהמערכת מחזיקה לחץ לפני שמשחררים.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">שירותים נלווים</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <a href="/services/electrical/" class="block p-5 bg-white/[0.04] border border-white/[0.09] rounded-lg hover:border-brand-500/40 hover:bg-white/[0.07] transition-all backdrop-blur-sm">
            <h3 class="font-bold text-white mb-2">⚡ חשמלאי רכב</h3>
            <p class="text-sm text-gray-400">תקלות חשמל שלעתים קשורות למיזוג — חיישני לחץ, ממסרים, פיוזים.</p>
          </a>
          <a href="/services/general-mechanics/" class="block p-5 bg-white/[0.04] border border-white/[0.09] rounded-lg hover:border-brand-500/40 hover:bg-white/[0.07] transition-all backdrop-blur-sm">
            <h3 class="font-bold text-white mb-2">🛠️ מכונאות כללית</h3>
            <p class="text-sm text-gray-400">טיפול שנתי כולל בדיקת מיזוג — מניעה עדיפה על תיקון.</p>
          </a>
          <a href="/services/ecu-reset/" class="block p-5 bg-white/[0.04] border border-white/[0.09] rounded-lg hover:border-brand-500/40 hover:bg-white/[0.07] transition-all backdrop-blur-sm">
            <h3 class="font-bold text-white mb-2">🔧 איפוס מחשב</h3>
            <p class="text-sm text-gray-400">נורית תקלה שנשארת לאחר תיקון — מחיקה ואיפוס.</p>
          </a>
        </div>
      </section>
    </div>
  </article>

  <FAQ items={faqs} title="שאלות נפוצות על תיקון מיזוג רכב" />
  <CTABanner title="המיזוג לא מקרר? אל תסבלו עוד קיץ" subtitle="ייעוץ חינמי, אבחון מדויק — נחזיר לכם קור אמיתי" />
</BaseLayout>
