---
import BaseLayout from '../../layouts/BaseLayout.astro'
import FAQ from '../../components/FAQ.astro'
import CTABanner from '../../components/CTABanner.astro'
import business from '../../data/business.js'

const title = 'תיקון נגררים | חשמל, פנסים ובלמים'
const description = 'תיקון נגררים מכל הסוגים — חיווט חשמלי, פנסים, מערכת בלימה ושילדה. שירות לחקלאים, יבואנים ונגרר בית. בעפולה והגלבוע.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'תיקון נגררים',
  provider: { '@id': `${business.url}#business` },
  areaServed: ['עפולה','מגדל העמק','נוף הגליל','יקנעם','טבריה','בית שאן','מגידו','נצרת'].map(a => ({ '@type': 'City', name: a })),
}

const faqs = [
  {
    q: 'מה התקלות הנפוצות ביותר בנגררים?',
    a: 'הבעיה הנפוצה ביותר היא חשמלית — פנסים שמפסיקים לעבוד, פלאשרים שלא מפלשרים, או חיבור 7/13 פינים פגום. סיבות: חיווט שנקרע, חיבורים מחוסנים, או נגיעה שנהרסה. בעיות מכניות נפוצות: גלגל עריץ שהתקלף, מנגנון מנוף שהתעקם, ועגלה שמנוקרת לאחרי. בלמים חשמליים — שחיקת רפידות, בעיית מגנטים.',
  },
  {
    q: 'האם אתם מתקנים גם נגררים חקלאיים ומסחריים?',
    a: 'כן, ואלו בדיוק הלקוחות שאנחנו מכירים הכי טוב — חקלאים וגידולי השדה באזור הגלבוע, עמק יזרעאל ועמק המעיינות הם חלק גדול מבסיס הלקוחות שלנו. נגרר לחמר, נגרר לחי, נגרר שדה, נגרר ציוד — אנחנו מטפלים בכולם.',
  },
  {
    q: 'כמה עולה תיקון חשמל בנגרר?',
    a: 'תיקון חיווט בסיסי (כמה נקודות שבורות + חיבורים) מתחיל ב-200-400 ₪. החלפת כבל חשמל מלאה עם ניתוב חדש עשויה להגיע ל-600-1,000 ₪ תלוי באורך הנגרר. החלפת פנסים שלמים — 300-600 ₪ לפי סוג. לקבלת הצעה מדויקת — בדיקה פיזית של הנגרר.',
  },
  {
    q: 'האם אתם עושים בדיקות מבחן רישוי לנגרר?',
    a: 'אנחנו מבצעים את התיקונים הנדרשים כדי שהנגרר יעבור מבחן רישוי — תיקון פנסים, בלמים, חיווט ותקינות שמשים (במידת הצורך). אנחנו לא מוסד רישוי, אבל אנחנו יודעים בדיוק מה הטסט בודק ומכינים את הנגרר בהתאם.',
  },
  {
    q: 'הנגרר שלי ישן מאוד — שווה לתקן?',
    a: 'תלוי בשמשה ובתקציב. נגרר ישן עם שילדה תקינה ראוי לתיקון חשמל ובלמים — עלויות אלו הן קטנות יחסית. כשהשילדה עצמה רקובה או עקומה — שם כבר ההמלצה שלנו תהיה שונה. נבדוק ונגיד בכנות.',
  },
]
---
<BaseLayout title={title} description={description} schema={schema}>
  <nav class="bg-[#040912] border-b border-white/[0.07] py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-gray-400">
      <a href="/" class="hover:text-white">בית</a><span class="mx-2">›</span>
      <a href="/services/" class="hover:text-white">שירותים</a><span class="mx-2">›</span>
      <span class="text-white font-medium">תיקון נגררים</span>
    </div>
  </nav>

  <section class="relative bg-[#040912] text-white py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0 tech-grid opacity-30 pointer-events-none" />
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(29,78,216,0.4) 0%, transparent 65%);" />
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        תיקון נגררים<br/>
        <span class="text-accent-500">בעפולה והגלבוע</span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        חיווט חשמלי, פנסים, בלמים ושילדה — לנגרר בית, קרוון, חקלאי ומסחרי.
        ניסיון רב עם לקוחות החקלאים של האזור.
      </p>
    </div>
  </section>

  <article class="py-12 md:py-16 bg-[#060d1e]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 prose-content">

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">נגרר תקול — בעיה שמפסיקה את היום</h2>
        <p class="text-gray-300 leading-relaxed text-lg mb-4">
          באזור עמק יזרעאל, הגלבוע ועמק המעיינות, נגרר הוא לא רק אביזר — הוא כלי עבודה.
          חקלאי שנגרר החקלאי שלו תקול מפסיד ימי עבודה. בעל קרוון שהפנסים לא עובדים
          לא יכול לצאת לטיול. אנחנו מכירים את הדחיפות הזו ועושים מאמץ להכניס תיקוני
          נגרר מהר ככל האפשר.
        </p>
        <p class="text-gray-300 leading-relaxed text-lg">
          ב<strong>אמיר מערכות</strong>, יש לנו ניסיון מצטבר של {business.stats.yearsOfExperience}+ שנים
          עם כל סוגי הנגררים שמסתובבים באזור — מנגרר קרוון דרך נגרר חקלאי ועד נגרר
          ציוד כבד. אנחנו יודעים בדיוק מה נכשל, איך לתקן, ואיך להחזיר אותם לכביש.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">מה אנחנו מתקנים בנגרר</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            { icon: '💡', t: 'פנסים ותאורה', d: 'החלפת נורות, יחידות פנס שלמות, פלאשרים ואורות בלם.' },
            { icon: '🔌', t: 'חיווט חשמלי', d: 'כבל חשמל שבור, חיבורים מחוסנים, ניתוב כבל חדש מהצמוד לנגרר.' },
            { icon: '🔗', t: 'חיבור 7/13 פינים', d: 'החלפת שקע/ניגל בצד הנגרר, בדיקה שכל הפינים עובדים.' },
            { icon: '🛑', t: 'מערכת בלמים', d: 'בלמי עגלה מכניים, בלמים חשמליים — שחיקת רפידות, מגנטים, כיול.' },
            { icon: '⚙️', t: 'מנגנון קיבוע ומנוף', d: 'ראש קיבוע שנהרס, מנוף שנקרה, ציר גרירה תקול.' },
            { icon: '🔧', t: 'שילדה ומבנה', d: 'ריתוך קטן, חיזוקים, פח עריץ — לנגררים שנפגעו בנסיעה.' },
          ].map(s => (
            <div class="p-5 bg-white/[0.04] border border-white/[0.09] rounded-xl backdrop-blur-sm">
              <div class="text-2xl mb-2">{s.icon}</div>
              <h3 class="font-bold text-white mb-2">{s.t}</h3>
              <p class="text-sm text-gray-400">{s.d}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">שירותים קשורים</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <a href="/services/towing-hitch/" class="block p-5 bg-white/[0.04] border border-white/[0.09] rounded-lg hover:border-brand-500/40 hover:bg-white/[0.07] transition-all backdrop-blur-sm">
            <h3 class="font-bold text-white mb-2">🔗 התקנת ווי גרירה</h3>
            <p class="text-sm text-gray-400">גם הרכב הגורר צריך וו מקצועי עם חיווט תקני.</p>
          </a>
          <a href="/services/electrical/" class="block p-5 bg-white/[0.04] border border-white/[0.09] rounded-lg hover:border-brand-500/40 hover:bg-white/[0.07] transition-all backdrop-blur-sm">
            <h3 class="font-bold text-white mb-2">⚡ חשמלאי רכב</h3>
            <p class="text-sm text-gray-400">תקלות חשמל ברכב הגורר — לעיתים קשורות לנגרר.</p>
          </a>
        </div>
      </section>
    </div>
  </article>

  <FAQ items={faqs} title="שאלות נפוצות על תיקון נגררים" />
  <CTABanner title="הנגרר לא עובד? נחזיר אתכם לכביש" subtitle="ייעוץ חינמי — מטפלים מהר בגלל שאנחנו מבינים את הדחיפות" />
</BaseLayout>
