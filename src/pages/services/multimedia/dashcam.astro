---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import FAQ from '../../../components/FAQ.astro'
import CTABanner from '../../../components/CTABanner.astro'
import business from '../../../data/business.js'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import Icon from '../../../components/Icon.astro'

const title = 'התקנת דאשקאם לרכב | מצלמות דרך עם מצב חנייה'
const description = 'התקנת דאשקאם מקצועית — מצלמת דרך חזיתית או דו-כיוונית, מצב חנייה, ראייה לילית. חיווט מוסתר, התקנה נקייה בעפולה והאזור, אחריות מלאה.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'התקנת דאשקאם (מצלמת דרך) לרכב',
  provider: {
    '@id': `${business.url}#business`,
  },
  areaServed: [
    'עפולה', 'מגדל העמק', 'נוף הגליל', 'יקנעם',
    'טבריה', 'בית שאן', 'מגידו', 'נצרת',
  ].map(a => ({ '@type': 'City', name: a })),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'דאשקאם — מצלמות דרך לרכב',
    itemListElement: [
      { '@type': 'Offer', name: 'דאשקאם חזיתי Full HD / 4K' },
      { '@type': 'Offer', name: 'דאשקאם דו-כיווני (חזית + אחור)' },
      { '@type': 'Offer', name: 'התקנת hardwire למצב חנייה 24/7' },
    ],
  },
}

const faqs = [
  {
    q: 'כמה עולה התקנת דאשקאם לרכב?',
    a: 'דאשקאם חזיתי איכותי עם התקנה מתחיל ב-500-800 ₪. דגם דו-כיווני (חזית + אחור) נע בין 900 ל-1,800 ₪, תלוי ברזולוציה ובפיצ\'רים. תוספת חיבור קבוע (hardwire) למצב חנייה 24/7 מוסיפה כ-150-300 ₪. הדגמים המתקדמים ב-4K עם GPS וצג מגע יקרים יותר. לקבלת הצעת מחיר מותאמת לרכב ולצרכים שלכם — צרו קשר.',
  },
  {
    q: 'מה זה מצב חנייה (Parking Mode) והאם שווה אותו?',
    a: 'מצב חנייה מאפשר לדאשקאם להמשיך לתעד גם כשהרכב חונה ומכובה — ומפעיל הקלטה אוטומטית כשמזוהה תנועה או זעזוע (לדוגמה, מישהו פוגע ברכב בחנייה ובורח). זה דורש חיבור קבוע לחשמל הרכב (hardwire) דרך קופסת הנתיכים, עם הגנה מפני התרוקנות מצבר. ללקוחות שחונים ברחוב או בחניונים — זה אחד הפיצ\'רים השווים ביותר, כי הוא מתעד פגיעות "פגע וברח" שאחרת אין דרך להוכיח.',
  },
  {
    q: 'מה ההבדל בין דאשקאם חזיתי לדו-כיווני?',
    a: 'דאשקאם חזיתי מתעד רק את מה שלפני הרכב — מספיק לרוב תאונות החזית והנהיגה ברחוב. דאשקאם דו-כיווני מוסיף מצלמה אחורית שמתעדת גם מה שקורה מאחור — חשוב במיוחד לתיעוד רכב שנכנס בכם מאחור, או נהיגה תוקפנית של רכב שעוקב. אנחנו ממליצים על דו-כיווני לרוב הנהגים — ההגנה המשפטית והביטוחית שווה את ההפרש.',
  },
  {
    q: 'האם הדאשקאם פוגע במצבר הרכב?',
    a: 'בהתקנה מקצועית — לא. כשמתקינים חיבור קבוע למצב חנייה, אנחנו מחברים דרך יחידת הגנה (cut-off) שמנתקת את הדאשקאם לפני שהמצבר יורד מתחת למתח בטוח. כך המצלמה מתעדת בחנייה אבל לעולם לא משאירה אתכם עם מצבר ריק. התקנה לא מקצועית בלי הגנה כזו אכן עלולה לרוקן מצבר — ולכן חשוב מי מתקין.',
  },
  {
    q: 'איפה מתקינים את הדאשקאם והאם רואים את החיווט?',
    a: 'הדאשקאם החזיתי מותקן מאחורי המראה הפנימית — מיקום מוסתר שלא חוסם את שדה הראייה ולא נראה מבחוץ. החיווט מועבר מוסתר לחלוטין דרך גומיות הגג והעמודים ועד קופסת הנתיכים, בלי כבלים תלויים. גם המצלמה האחורית (בדגם דו-כיווני) מותקנת בצורה אסתטית ליד החלון האחורי. התוצאה נראית מסודרת ומקצועית כמו התקנת יצרן.',
  },
  {
    q: 'האם הדאשקאם מקליט באיכות טובה בלילה?',
    a: `הדגמים שאנחנו מתקינים כוללים חיישני ${'Sony STARVIS'} או מקבילים, שמיועדים לראייה לילית — קולטים מספרי רכב ופרטים גם בתאורה נמוכה. ברזולוציית Full HD ומעלה, ובמיוחד ב-4K, התיעוד הלילי חד מספיק כדי לזהות לוחית רישוי של רכב אחר. זה בדיוק מה שמבדיל דאשקאם איכותי מדגם זול שמראה לילה מטושטש וחסר תועלת.`,
  },
  {
    q: 'האם הקלטות הדאשקאם קבילות לביטוח ולמשטרה?',
    a: 'כן. הקלטות דאשקאם משמשות באופן קבוע כראיה בתביעות ביטוח ובדיווחים למשטרה בישראל. הדגמים שלנו מטביעים על הסרטון חותמת זמן, תאריך, ובדגמים עם GPS גם מהירות ומיקום — מה שמחזק את קבילות הראיה. תיעוד ברור של תאונה יכול לחסוך לכם אלפי שקלים והרבה כאב ראש מול חברת הביטוח.',
  },
  {
    q: 'מה האחריות שאתם נותנים?',
    a: 'אחריות מלאה על העבודה (חיווט והתקנה) ואחריות יצרן מלאה על הדאשקאם עצמו. אם מתגלה בעיה בחיווט, במצב החנייה או בהתקנה — מחזירים אלינו והכל מתוקן ללא תשלום. אנחנו עומדים מאחורי כל התקנה.',
  },
]
---

<BaseLayout title={title} description={description} schema={schema}>

  <Breadcrumb items={[{label: 'מולטימדיה', href: '/services/multimedia/'}, {label: 'דאשקאם'}]} />

  <!-- Hero -->
  <section class="relative bg-[#040912] text-white py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0 tech-grid opacity-30 pointer-events-none" />
    <div class="absolute inset-0 pointer-events-none hero-radial" />
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        התקנת דאשקאם לרכב<br/>
        <span class="text-accent-500">בעפולה והגלבוע</span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        מצלמות דרך חזיתיות ודו-כיווניות, עם מצב חנייה 24/7 וראייה לילית.
        התקנה מקצועית עם חיווט מוסתר, הגנת מצבר, ואחריות מלאה.
      </p>
    </div>
  </section>

  <!-- Main content -->
  <article class="py-12 md:py-16 bg-[#060d1e]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 prose-content">

      <!-- Intro -->
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          דאשקאם — העד השקט שמגן עליכם בכל נסיעה
        </h2>
        <p class="text-gray-300 leading-relaxed text-lg mb-4">
          בכביש, רגע אחד יכול לשנות הכל. תאונה, נהג שנכנס בכם ובורח, ויכוח על "מי אשם" —
          בכל אחד מהמצבים האלו, ההקלטה של הדאשקאם היא ההבדל בין ראיה ברורה לבין מילה
          שלכם מול מילה שלהם. דאשקאם הוא לא מותרות — הוא הביטוח הזול ביותר שתקנו לרכב,
          וכזה שמשתלם ברגע האמת.
        </p>
        <p class="text-gray-300 leading-relaxed text-lg">
          ב<strong>אמיר מערכות</strong>, אנחנו מתקינים דאשקאם בצורה מקצועית כבר {business.stats.yearsOfExperience}+ שנים
          באזור עפולה, הגלבוע ועמק יזרעאל. אנחנו לא רק "תוקעים מצלמה על השמשה" — אנחנו
          מתקינים בחיווט קבוע ומוסתר, עם הגנת מצבר למצב חנייה, ובוחרים יחד אתכם את הדגם
          הנכון לפי התקציב והצרכים, בלי למכור לכם פיצ\'רים שלא תשתמשו בהם.
        </p>
      </section>

      <!-- What's in it for you -->
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">
          מה תקבלו מדאשקאם מותקן מקצועית?
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="p-5 glass-card">
            <div class="w-11 h-11 bg-brand-500/15 text-brand-400 rounded-xl flex items-center justify-center mb-3"><Icon name="shield" class="w-5 h-5" /></div>
            <h3 class="font-bold text-white mb-2">ראיה לביטוח ולמשטרה</h3>
            <p class="text-sm text-gray-400">
              תיעוד חד עם חותמת זמן ומיקום — קביל בתביעות ביטוח ובדיווח למשטרה.
            </p>
          </div>
          <div class="p-5 glass-card">
            <div class="text-2xl mb-2">🅿️</div>
            <h3 class="font-bold text-white mb-2">מצב חנייה 24/7</h3>
            <p class="text-sm text-gray-400">
              מתעד פגיעות "פגע וברח" גם כשהרכב חונה ומכובה, עם זיהוי זעזוע.
            </p>
          </div>
          <div class="p-5 glass-card">
            <div class="w-11 h-11 bg-brand-500/15 text-brand-400 rounded-xl flex items-center justify-center mb-3"><Icon name="star" class="w-5 h-5" /></div>
            <h3 class="font-bold text-white mb-2">ראייה לילית חדה</h3>
            <p class="text-sm text-gray-400">
              חיישן Sony STARVIS או מקביל — קולט לוחיות רישוי גם בתאורה נמוכה.
            </p>
          </div>
          <div class="p-5 glass-card">
            <div class="w-11 h-11 bg-brand-500/15 text-brand-400 rounded-xl flex items-center justify-center mb-3"><Icon name="zap" class="w-5 h-5" /></div>
            <h3 class="font-bold text-white mb-2">הגנת מצבר חכמה</h3>
            <p class="text-sm text-gray-400">
              יחידת cut-off מנתקת לפני שהמצבר יורד — בלי לחשוש להישאר תקועים.
            </p>
          </div>
          <div class="p-5 glass-card">
            <div class="w-11 h-11 bg-brand-500/15 text-brand-400 rounded-xl flex items-center justify-center mb-3"><Icon name="video" class="w-5 h-5" /></div>
            <h3 class="font-bold text-white mb-2">תיעוד דו-כיווני</h3>
            <p class="text-sm text-gray-400">
              חזית + אחור — מכסה גם רכב שנכנס בכם מאחור או עוקב תוקפני.
            </p>
          </div>
          <div class="p-5 glass-card">
            <div class="w-11 h-11 bg-brand-500/15 text-brand-400 rounded-xl flex items-center justify-center mb-3"><Icon name="wrench" class="w-5 h-5" /></div>
            <h3 class="font-bold text-white mb-2">התקנה נקייה ומוסתרת</h3>
            <p class="text-sm text-gray-400">
              מאחורי המראה, חיווט מוסתר לגמרי — בלי כבלים תלויים על השמשה.
            </p>
          </div>
        </div>
      </section>

      <!-- Types -->
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">
          סוגי דאשקאם שאנחנו מתקינים
        </h2>
        <div class="space-y-4">
          <div class="p-5 glass-card">
            <h3 class="font-bold text-white mb-1">דאשקאם חזיתי Full HD / 4K</h3>
            <p class="text-gray-300">מצלמה יחידה שמתעדת את החזית. הפתרון המשתלם והנפוץ ביותר, מספיק לרוב הנהגים. דגמי 4K נותנים חדות גבוהה במיוחד לזיהוי פרטים.</p>
          </div>
          <div class="p-5 glass-card">
            <h3 class="font-bold text-white mb-1">דאשקאם דו-כיווני (חזית + אחור)</h3>
            <p class="text-gray-300">שתי מצלמות שמתעדות גם קדימה וגם אחורה בו-זמנית. ההמלצה שלנו לרוב הלקוחות — כיסוי מלא והגנה משפטית מקסימלית.</p>
          </div>
          <div class="p-5 glass-card">
            <h3 class="font-bold text-white mb-1">דאשקאם עם GPS</h3>
            <p class="text-gray-300">מוסיף נתוני מהירות ומיקום מדויקים על גבי ההקלטה — מחזק את קבילות הראיה ומתעד את מסלול הנסיעה.</p>
          </div>
          <div class="p-5 glass-card">
            <h3 class="font-bold text-white mb-1">חיבור קבוע (Hardwire) למצב חנייה</h3>
            <p class="text-gray-300">תוספת חיווט מקופסת הנתיכים שמאפשרת תיעוד גם בחנייה, עם יחידת הגנה מפני התרוקנות מצבר.</p>
          </div>
        </div>
      </section>

      <!-- Process -->
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">
          תהליך ההתקנה — שלב אחר שלב
        </h2>
        <ol class="space-y-4">
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-500/20 border border-brand-500/40 text-brand-300 rounded-full flex items-center justify-center font-bold">1</div>
            <div>
              <h3 class="font-bold text-white mb-1">ייעוץ והתאמת דגם</h3>
              <p class="text-gray-300">מבינים את הצורך — חזיתי או דו-כיווני, האם נדרש מצב חנייה — וממליצים על הדגם המתאים לתקציב ולשימוש. שיחה ללא עלות וללא התחייבות.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-500/20 border border-brand-500/40 text-brand-300 rounded-full flex items-center justify-center font-bold">2</div>
            <div>
              <h3 class="font-bold text-white mb-1">הצעת מחיר ותיאום תור</h3>
              <p class="text-gray-300">הצעת מחיר סופית כולל תוספות (hardwire, GPS). תיאום תור בהתאם לזמינות שלכם, בדרך כלל תוך 2-7 ימים.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-500/20 border border-brand-500/40 text-brand-300 rounded-full flex items-center justify-center font-bold">3</div>
            <div>
              <h3 class="font-bold text-white mb-1">התקנה וחיווט מוסתר</h3>
              <p class="text-gray-300">התקנת המצלמה מאחורי המראה, העברת חיווט מוסתר דרך הגג והעמודים, וחיבור לחשמל. בדגם דו-כיווני — גם התקנת המצלמה האחורית.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-500/20 border border-brand-500/40 text-brand-300 rounded-full flex items-center justify-center font-bold">4</div>
            <div>
              <h3 class="font-bold text-white mb-1">חיבור מצב חנייה והגדרות</h3>
              <p class="text-gray-300">חיבור hardwire דרך קופסת הנתיכים עם יחידת הגנת מצבר (במצב חנייה), והגדרת רגישות הזעזוע, רזולוציה וחותמת זמן.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-500/20 border border-brand-500/40 text-brand-300 rounded-full flex items-center justify-center font-bold">5</div>
            <div>
              <h3 class="font-bold text-white mb-1">בדיקות, הדגמה ואחריות</h3>
              <p class="text-gray-300">בדיקת איכות ההקלטה ביום ובלילה, הדגמה של גישה לסרטונים מהאפליקציה/כרטיס, ואחריות מלאה על העבודה.</p>
            </div>
          </li>
        </ol>
      </section>

      <!-- Why us -->
      <section class="mb-12 p-6 glass-section">
        <h2 class="text-xl md:text-2xl font-bold text-white mb-4">
          למה התקנה מקצועית של דאשקאם חשובה
        </h2>
        <p class="text-gray-300 leading-relaxed mb-4">
          דאשקאם שמותקן עם מטען לשקע המצית וכבל תלוי על השמשה הוא לא רק מכוער —
          הוא גם לא יעבוד במצב חנייה, יתנתק בכל פעם שמכבים את הרכב, ועלול ליפול.
          התקנה מקצועית פירושה <strong>חיבור קבוע מוסתר, הגנת מצבר, וחיווט אטום</strong>
          שמחזיק שנים.
        </p>
        <p class="text-gray-300 leading-relaxed">
          אנחנו עובדים עם המותגים המובילים בתחום — <strong>Viofo, 70mai, Nextbase</strong>
          ו-<strong>BlackVue</strong> — ובוחרים יחד אתכם את הדגם שמתאים לצורך, לא את היקר ביותר.
          חשוב לנו שתצאו מאיתנו עם מערכת שתשרת אתכם אמין ברגע שתצטרכו אותה באמת.
        </p>
      </section>

      <!-- Internal links -->
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">
          שירותים נלווים שאולי יעניינו אתכם
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
