---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import FAQ from '../../../components/FAQ.astro'
import CTABanner from '../../../components/CTABanner.astro'
import business from '../../../data/business.js'

const title = 'מערכת שמע לרכב | רמקולים, סאבוופר ומגברים'
const description = 'שדרוג מערכת השמע ברכב — רמקולים איכותיים, סאבוופרים, מגברים וכיוונון מקצועי. התקנה בעפולה והאזור, צליל קונצרטי, אחריות מלאה.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'התקנת מערכת שמע ורמקולים לרכב',
  provider: {
    '@id': `${business.url}#business`,
  },
  areaServed: [
    'עפולה', 'מגדל העמק', 'נוף הגליל', 'יקנעם',
    'טבריה', 'בית שאן', 'מגידו', 'נצרת',
  ].map(a => ({ '@type': 'City', name: a })),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'מערכות שמע ורמקולים לרכב',
    itemListElement: [
      { '@type': 'Offer', name: 'החלפת רמקולים (קומפוננט / קואקסיאלי)' },
      { '@type': 'Offer', name: 'התקנת סאבוופר ומגבר' },
      { '@type': 'Offer', name: 'כוונון ואקולייזר מקצועי (DSP)' },
    ],
  },
}

const faqs = [
  {
    q: 'כמה עולה שדרוג מערכת שמע לרכב?',
    a: 'שדרוג בסיסי של זוג רמקולים קדמיים איכותיים עם התקנה מתחיל ב-600-1,000 ₪. החלפה מלאה של כל הרמקולים נעה סביב 1,500-2,500 ₪. הוספת סאבוופר ומגבר לבס עוצמתי מוסיפה 1,500-3,500 ₪, תלוי בציוד. מערכת פרימיום מלאה עם DSP, מגברים וכיוונון מקצועי יכולה להגיע ל-5,000 ₪ ומעלה. בונים יחד אתכם חבילה לפי התקציב — צרו קשר להצעה.',
  },
  {
    q: 'למה כדאי להחליף את הרמקולים המקוריים?',
    a: 'הרמקולים שמגיעים מהיצרן ברוב הרכבים הם מהזולים בשוק — הם מתוכננים לעלות מינימום, לא להישמע טוב. רמקולי aftermarket איכותיים נותנים הפרדה ברורה בין הצלילים, בס נקי בלי עיוותים, וגבהים פריכים. ההבדל מורגש מיד, גם בלי מגבר נוסף. זה אחד השדרוגים שנותנים את ההנאה היומיומית הגדולה ביותר ביחס לעלות.',
  },
  {
    q: 'מה ההבדל בין רמקול קומפוננט לקואקסיאלי?',
    a: 'רמקול קואקסיאלי (Coaxial) הוא יחידה אחת שמשלבת את כל התדרים — קל להתקנה, מחיר נוח, ומשדרג משמעותית את המקור. רמקול קומפוננט (Component) מפצל את הטוויטר (הגבהים) מהוופר (הבס) ליחידות נפרדות, מה שנותן במה צלילית מדויקת ואיכות גבוהה יותר — אבל דורש התקנה מורכבת יותר. אנחנו ממליצים על האפשרות שמתאימה לתקציב ולרמת האוזן שלכם.',
  },
  {
    q: 'האם אני חייב מגבר וסאבוופר?',
    a: 'לא חייבים — תלוי מה אתם מחפשים. אם רוצים שיפור כללי באיכות הצליל, החלפת רמקולים בלבד תעשה עבודה מצוינת. אם אתם אוהבים בס עוצמתי ועמוק (היפ-הופ, אלקטרונית), סאבוופר ייעודי הוא הדרך היחידה להגיע לזה. מגבר נכנס לתמונה כשרוצים להוציא את המקסימום מהרמקולים והסאב — הוא מספק הספק נקי בלי עיוותים בעוצמה גבוהה.',
  },
  {
    q: 'מה זה כיוונון DSP ולמה הוא חשוב?',
    a: 'DSP (Digital Sound Processor) הוא מעבד שמאפשר לכוונן בדיוק את הצליל לתוך תא הנוסעים הספציפי שלכם — לתקן את ההשהיה של כל רמקול, לאזן תדרים, ולמקם את "הבמה הצלילית" מול הנהג. בלי כיוונון, אפילו ציוד יקר יישמע בינוני בגלל האקוסטיקה של הרכב. עם כיוונון מקצועי, גם מערכת בינונית נשמעת הרבה מעל המחיר שלה. זה השלב שמבדיל בין "החלפתי רמקולים" לבין "מערכת שמע אמיתית".',
  },
  {
    q: 'האם השדרוג ידרוש שינויים ברכב או חיתוכים?',
    a: 'ברוב המקרים לא. רמקולים מותקנים במקומות המקוריים עם מתאמים (אדפטרים) ייעודיים לכל דגם רכב, בלי חיתוכים. סאבוופר ומגבר מותקנים בתא המטען בצורה מסודרת. אנחנו תמיד שואפים להתקנה הפיכה ונקייה — כך שאם תמכרו את הרכב, אפשר להחזיר אותו למצב המקורי. כל חיווט נעשה מקצועי, מבודד ומוסתר.',
  },
  {
    q: 'כמה זמן לוקחת ההתקנה?',
    a: 'החלפת זוג רמקולים אורכת כ-1.5-2.5 שעות. מערכת מלאה עם סאבוופר, מגבר וכיוונון יכולה לקחת חצי יום עד יום עבודה, כי הכיוונון המקצועי דורש זמן ואוזן קשבת. אנחנו לא ממהרים בשלב הכיוונון — שם נמצאת רוב האיכות, ושווה להשקיע בו את הזמן.',
  },
  {
    q: 'מה האחריות שאתם נותנים?',
    a: 'אחריות 3 שנים על העבודה (התקנה וחיווט) ואחריות יצרן מלאה על הרכיבים (רמקולים, מגבר, סאב). אם משהו מזמזם, מתעוות או מפסיק לעבוד — חוזרים אלינו והכל מטופל ללא תשלום. אנחנו עומדים מאחורי כל מערכת שאנחנו בונים.',
  },
]
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-200 py-3" aria-label="breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-gray-600">
      <a href="/" class="hover:text-brand-700">בית</a>
      <span class="mx-2">›</span>
      <a href="/services/multimedia/" class="hover:text-brand-700">מולטימדיה</a>
      <span class="mx-2">›</span>
      <span class="text-gray-900 font-medium">מערכות שמע</span>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-gradient-to-bl from-brand-900 to-brand-700 text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        מערכת שמע ורמקולים לרכב<br/>
        <span class="text-accent-500">בעפולה והגלבוע</span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        שדרוג מלא לאיכות הצליל — רמקולים איכותיים, סאבוופרים, מגברים וכיוונון DSP מקצועי.
        התקנה נקייה, צליל קונצרטי, ואחריות מלאה.
      </p>
    </div>
  </section>

  <!-- Main content -->
  <article class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 prose-content">

      <!-- Intro -->
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
          מערכת שמע לרכב — תהפכו כל נסיעה לחוויה
        </h2>
        <p class="text-gray-700 leading-relaxed text-lg mb-4">
          אתם מבלים שעות ברכב — בדרך לעבודה, בטיולים, בפקקים. הרמקולים המקוריים שמגיעים
          ברוב הרכבים מהיצרן הם מהזולים בשוק, ומשטיחים את המוזיקה לצליל שטוח וחסר חיים.
          שדרוג מערכת השמע הוא אחד השדרוגים שנותנים את ההנאה היומיומית הגדולה ביותר —
          פתאום אתם שומעים פרטים בשירים שאהבתם שנים, עם בס נקי וגבהים ברורים.
        </p>
        <p class="text-gray-700 leading-relaxed text-lg">
          ב<strong>אמיר מערכות</strong>, אנחנו בונים מערכות שמע לרכב כבר {business.stats.yearsOfExperience}+ שנים
          באזור עפולה, הגלבוע ועמק יזרעאל. אנחנו לא מאמינים ב"כמה שיותר רמקולים וכמה שיותר ווטים" —
          אנחנו מאמינים בהתאמה נכונה של רכיבים, התקנה מקצועית, וכיוונון מדויק לתא הנוסעים שלכם.
          זה ההבדל בין רעש חזק לבין צליל אמיתי ונקי.
        </p>
      </section>

      <!-- What's in it for you -->
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
          מה כולל שדרוג מערכת שמע?
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="p-5 bg-gray-50 rounded-lg border border-gray-200">
            <div class="text-2xl mb-2">🔊</div>
            <h3 class="font-bold text-gray-900 mb-2">רמקולים איכותיים</h3>
            <p class="text-sm text-gray-600">
              קומפוננט או קואקסיאלי — הפרדת צלילים, בס נקי וגבהים פריכים בלי עיוותים.
            </p>
          </div>
          <div class="p-5 bg-gray-50 rounded-lg border border-gray-200">
            <div class="text-2xl mb-2">🎸</div>
            <h3 class="font-bold text-gray-900 mb-2">סאבוופר לבס עמוק</h3>
            <p class="text-sm text-gray-600">
              בס עוצמתי ונקי שמרגישים בחזה — מושלם להיפ-הופ, אלקטרונית ורוק.
            </p>
          </div>
          <div class="p-5 bg-gray-50 rounded-lg border border-gray-200">
            <div class="text-2xl mb-2">⚡</div>
            <h3 class="font-bold text-gray-900 mb-2">מגבר (אמפליפייר)</h3>
            <p class="text-sm text-gray-600">
              הספק נקי שמוציא את המקסימום מהרמקולים — בלי עיוותים גם בעוצמה גבוהה.
            </p>
          </div>
          <div class="p-5 bg-gray-50 rounded-lg border border-gray-200">
            <div class="text-2xl mb-2">🎚️</div>
            <h3 class="font-bold text-gray-900 mb-2">כיוונון DSP מקצועי</h3>
            <p class="text-sm text-gray-600">
              איזון תדרים והשהיות לפי האקוסטיקה של הרכב — במה צלילית מדויקת.
            </p>
          </div>
          <div class="p-5 bg-gray-50 rounded-lg border border-gray-200">
            <div class="text-2xl mb-2">🔇</div>
            <h3 class="font-bold text-gray-900 mb-2">בידוד אקוסטי (אופציונלי)</h3>
            <p class="text-sm text-gray-600">
              בידוד דלתות שמפחית רעשי דרך ומשפר משמעותית את איכות הבס.
            </p>
          </div>
          <div class="p-5 bg-gray-50 rounded-lg border border-gray-200">
            <div class="text-2xl mb-2">🧩</div>
            <h3 class="font-bold text-gray-900 mb-2">התקנה הפיכה ונקייה</h3>
            <p class="text-sm text-gray-600">
              מתאמים ייעודיים לכל דגם, בלי חיתוכים — אפשר להחזיר למקור בעת מכירה.
            </p>
          </div>
        </div>
      </section>

      <!-- Build options -->
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
          רמות שדרוג — מהבסיסי ועד הפרימיום
        </h2>
        <div class="space-y-4">
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-1">שלב 1 — החלפת רמקולים קדמיים</h3>
            <p class="text-gray-700">השדרוג המשתלם ביותר. זוג רמקולים איכותיים במקום המקוריים — שיפור מיידי ומורגש, בלי שינויים נוספים ברכב.</p>
          </div>
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-1">שלב 2 — מערכת רמקולים מלאה</h3>
            <p class="text-gray-700">החלפת כל הרמקולים (קדמיים ואחוריים), לרוב בליווי מגבר קטן. צליל מאוזן ומלא בכל תא הנוסעים.</p>
          </div>
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-1">שלב 3 — תוספת סאבוופר ומגבר</h3>
            <p class="text-gray-700">סאבוופר ייעודי בתא המטען עם מגבר נפרד — בס עמוק ונקי שמשנה לגמרי את חוויית ההאזנה.</p>
          </div>
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-1">שלב 4 — מערכת פרימיום עם DSP</h3>
            <p class="text-gray-700">רכיבים איכותיים, מגברים נפרדים, ומעבד DSP עם כיוונון מקצועי מלא. הרמה הגבוהה ביותר — צליל ברמת סטודיו.</p>
          </div>
        </div>
      </section>

      <!-- Process -->
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
          תהליך השדרוג — שלב אחר שלב
        </h2>
        <ol class="space-y-4">
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-900 text-white rounded-full flex items-center justify-center font-bold">1</div>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">הקשבה והבנת הטעם המוזיקלי</h3>
              <p class="text-gray-700">מבינים איזו מוזיקה אתם אוהבים, מה התקציב, ומה מפריע לכם בצליל הנוכחי. ממליצים על רכיבים שמתאימים בדיוק לאוזן ולתקציב שלכם. ייעוץ ללא עלות.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-900 text-white rounded-full flex items-center justify-center font-bold">2</div>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">הצעת מחיר ובניית חבילה</h3>
              <p class="text-gray-700">בונים חבילת רכיבים מאוזנת — בלי לבזבז על רכיב אחד יקר שלא מתאים לשאר. הצעת מחיר שקופה ותיאום תור.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-900 text-white rounded-full flex items-center justify-center font-bold">3</div>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">התקנה מקצועית</h3>
              <p class="text-gray-700">התקנת הרמקולים עם מתאמים ייעודיים, מיקום הסאב והמגבר בתא המטען, וחיווט נקי ומבודד. הכל מסודר והפיך.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-900 text-white rounded-full flex items-center justify-center font-bold">4</div>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">כיוונון מקצועי (Tuning)</h3>
              <p class="text-gray-700">השלב הקריטי — כיוונון תדרים, השהיות ועוצמות לפי האקוסטיקה של הרכב. כאן נמצאת רוב האיכות, ואנחנו לא ממהרים בו.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-900 text-white rounded-full flex items-center justify-center font-bold">5</div>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">האזנה משותפת ואחריות</h3>
              <p class="text-gray-700">מאזינים יחד, מכווננים לפי ההעדפה שלכם, ומסבירים את השליטה במערכת. 3 שנות אחריות על העבודה.</p>
            </div>
          </li>
        </ol>
      </section>

      <!-- Brands -->
      <section class="mb-12 p-6 bg-gray-50 rounded-xl">
        <h2 class="text-xl md:text-2xl font-bold text-gray-900 mb-4">
          המותגים שאנחנו עובדים איתם
        </h2>
        <p class="text-gray-700 leading-relaxed mb-4">
          אנחנו עובדים עם מותגי השמע המובילים בעולם הרכב — <strong>Pioneer, Alpine, JBL,
          Focal, Hertz</strong> ו-<strong>Kenwood</strong>. לכל מותג אופי צליל משלו, ואנחנו
          מתאימים את הרכיבים לטעם המוזיקלי שלכם: Focal ו-Hertz מצטיינים בדיוק ובפירוט,
          JBL ו-Pioneer נותנים יחס מחיר/ביצועים מצוין, ו-Alpine מובילים באמינות וכיוונון.
        </p>
        <p class="text-gray-700 leading-relaxed">
          חשוב לנו להבהיר: <strong>מערכת מאוזנת תמיד תנצח רכיב יקר בודד</strong>. רמקול
          פרימיום שמחובר למקור חלש או בלי כיוונון יישמע פחות טוב ממערכת בינונית מותקנת
          ומכווננת נכון. לכן אנחנו ממליצים תמיד על חבילה הגיונית — ולא על "הכי יקר שיש".
        </p>
      </section>

      <!-- Internal links -->
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
          שירותים נלווים שאולי יעניינו אתכם
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <a href="/services/multimedia/android-screens/" class="block p-5 bg-white border border-gray-200 rounded-lg hover:border-brand-500 hover:shadow transition">
