---
import BaseLayout from '../../layouts/BaseLayout.astro'
import FAQ from '../../components/FAQ.astro'
import CTABanner from '../../components/CTABanner.astro'
import business from '../../data/business.js'
import { areas } from '../../data/areas.js'

const area = areas.find(a => a.slug === 'nazareth')
const title = area.metaTitle
const description = area.metaDescription

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'מולטימדיה ושירותי רכב בנצרת',
  provider: { '@id': `${business.url}#business` },
  areaServed: { '@type': 'City', name: 'נצרת' },
}

const services = [
  { icon: '📱', t: 'מסכי אנדרואיד', href: '/services/multimedia/android-screens/', d: 'CarPlay ו-Android Auto — התקנה יומית, אחריות 3 שנים.' },
  { icon: '📹', t: 'מצלמות רוורס', href: '/services/multimedia/parking-cameras/', d: 'מצלמה אחורית, 360° וחיישני חנייה — לרחובות הצרים.' },
  { icon: '🎥', t: 'דאשקאם', href: '/services/multimedia/dashcam/', d: 'הגנה ביטוחית — עם מצב חנייה.' },
  { icon: '🔊', t: 'מערכות שמע', href: '/services/multimedia/sound-systems/', d: 'רמקולים, מגבר וסאבוופר — שדרוג אמיתי.' },
  { icon: '⚡', t: 'חשמלאי רכב', href: '/services/electrical/', d: 'דיאגנוסטיקה ותיקון תקלות חשמל.' },
  { icon: '🔗', t: 'ווי גרירה', href: '/services/towing-hitch/', d: 'קבוע, נשלף, חיבור 7/13 פינים.' },
  { icon: '❄️', t: 'מיזוג רכב', href: '/services/ac-repair/', d: 'מילוי גז ותיקון — מיזוג שעובד.' },
  { icon: '🛠️', t: 'מכונאות', href: '/services/general-mechanics/', d: 'טיפולים, בלמים ומתלים.' },
]

const faqs = [
  { q: 'כמה זמן נסיעה מנצרת אליכם?', a: `נצרת נמצאת ${area.distance} ק"מ מהסדנה שלנו — כ-25-30 דקות דרך כביש 60 דרומה לכיוון עפולה ומשם לגלבוע. הדרך נוחה ורוב הנסיעה בכביש מהיר.` },
  { q: 'האם אתם עובדים עם לקוחות ערבים?', a: 'בהחלט — לקוחות מנצרת, כפר קנא, עמנואל, ג׳לג׳וליה ועוד יישובים ערביים הם חלק מבסיס הלקוחות שלנו. השירות ניתן בעברית; ניתן לתאם בערבית דרך וואטסאפ.' },
  { q: 'יש לכם ניסיון עם דגמי רכב נפוצים בנצרת?', a: `נצרת עם ${area.population.toLocaleString()} תושבים היא שוק גדול — ויש בה שפע של טויוטה קורולה, קיה ספורטאז׳, יונדאי טוסון ורכבי משפחה. אנחנו עובדים עם כל הדגמים האלה כל יום. אם יש דגם ספציפי — שאלו דרך וואטסאפ.` },
  { q: 'האם שווה לנסוע מנצרת?', a: 'לקוחות מנצרת שמגיעים אלינו מעידים שהשירות שלנו מצדיק את הנסיעה. 25 דקות הלוך, העבודה מתבצעת ביום אחד, ומקבלים אחריות מלאה — עדיף מלסכן עם עבודה לא מקצועית ברחוב.' },
]
---
<BaseLayout title={title} description={description} schema={schema}>
  <nav class="bg-[#040912] border-b border-white/[0.07] py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-gray-400">
      <a href="/" class="hover:text-white">בית</a><span class="mx-2">›</span>
      <a href="/areas/" class="hover:text-white">אזורי שירות</a><span class="mx-2">›</span>
      <span class="text-white font-medium">נצרת</span>
    </div>
  </nav>

  <section class="relative bg-[#040912] text-white py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0 tech-grid opacity-30 pointer-events-none" />
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(29,78,216,0.4) 0%, transparent 65%);" />
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="inline-block bg-white/10 rounded-full px-4 py-1 text-sm font-medium mb-4">{area.distance} ק"מ מנצרת — כ-25 דקות</div>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        מולטימדיה ושירותי רכב<br/><span class="text-accent-500">לתושבי נצרת והגליל התחתון</span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        מסכים, מצלמות, חשמלאות וווי גרירה — שירות מקצועי {area.distance} ק"מ מנצרת, עם אחריות על כל עבודה.
      </p>
    </div>
  </section>

  <article class="py-12 md:py-16 bg-[#060d1e]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 prose-content">
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">לתושבי נצרת — שירות מקצועי בכל הגליל</h2>
        <p class="text-gray-300 leading-relaxed text-lg mb-4">
          נצרת, עם {area.population.toLocaleString()} תושבים, היא עיר הגדולה ביותר בגליל התחתון
          ומרכז מסחרי ותרבותי לכל האזור. תושבי נצרת ותושבי היישובים הסמוכים — כפר כנא,
          עמנואל, מגד אל-כרום — מחפשים שירותי רכב מקצועיים, מהירים ושקופים.
        </p>
        <p class="text-gray-300 leading-relaxed text-lg">
          ב<strong>אמיר מערכות</strong>, {area.distance} ק"מ מנצרת, אנחנו נותנים שירות לכל תושבי
          הגליל — ללא הבדל. ניסיון {business.stats.yearsOfExperience}+ שנים, מעל {business.stats.installationsCount.toLocaleString()} התקנות,
          ואחריות מלאה על כל עבודה.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">השירותים לתושבי נצרת</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {services.map(s => (
            <a href={s.href} class="block p-5 bg-white/[0.04] border border-white/[0.09] rounded-xl hover:border-brand-500/40 hover:bg-white/[0.07] transition-all backdrop-blur-sm">
              <div class="text-2xl mb-2">{s.icon}</div>
              <h3 class="font-bold text-white mb-1">{s.t}</h3>
              <p class="text-sm text-gray-400">{s.d}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="p-5 bg-white/[0.05] border border-white/[0.09] rounded-xl text-center">
            <div class="text-3xl font-bold text-accent-500 mb-1">{business.stats.yearsOfExperience}+</div>
            <div class="text-sm text-blue-200">שנות ניסיון</div>
          </div>
          <div class="p-5 bg-white/[0.05] border border-white/[0.09] rounded-xl text-center">
            <div class="text-3xl font-bold text-accent-500 mb-1">{business.stats.installationsCount.toLocaleString()}+</div>
            <div class="text-sm text-blue-200">התקנות בוצעו</div>
          </div>
          <div class="p-5 bg-white/[0.05] border border-white/[0.09] rounded-xl text-center">
            <div class="text-3xl font-bold text-accent-500 mb-1">{area.distance} ק"מ</div>
            <div class="text-sm text-blue-200">מנצרת</div>
          </div>
        </div>
      </section>

      <section class="mb-12 p-6 bg-blue-50 rounded-xl border border-blue-100">
        <h2 class="text-xl font-bold text-white mb-3">איך מגיעים מנצרת לסדנה?</h2>
        <p class="text-gray-300 leading-relaxed">
          מנצרת: כביש 60 דרומה לכיוון עפולה ← סמוך לעפולה פנייה מזרחה לגלבוע ← כביש 667 ← מושב מלאה.
          נסיעה של כ-25 דקות בתנאים רגילים. כתבו לנו בוואטסאפ ונשלח ווייז.
        </p>
      </section>
    </div>
  </article>

  <FAQ items={faqs} title="שאלות נפוצות מתושבי נצרת" />
  <CTABanner title="תושב נצרת? 25 דקות נסיעה לשירות מקצועי" subtitle="ייעוץ חינמי — שואלים בוואטסאפ, מגיעים ביום הנוח" />
</BaseLayout>
