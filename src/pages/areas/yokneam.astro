---
import BaseLayout from '../../layouts/BaseLayout.astro'
import FAQ from '../../components/FAQ.astro'
import CTABanner from '../../components/CTABanner.astro'
import business from '../../data/business.js'
import { areas } from '../../data/areas.js'

const area = areas.find(a => a.slug === 'yokneam')
const title = area.metaTitle
const description = area.metaDescription

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'מולטימדיה ושירותי רכב ביקנעם',
  provider: { '@id': `${business.url}#business` },
  areaServed: { '@type': 'City', name: 'יקנעם' },
}

const services = [
  { icon: '📱', t: 'מסכי אנדרואיד', href: '/services/multimedia/android-screens/', d: 'CarPlay ו-Android Auto — ההתקנה הפופולרית.' },
  { icon: '📹', t: 'מצלמות רוורס', href: '/services/multimedia/parking-cameras/', d: 'מצלמה אחורית, 360° וחיישני חנייה.' },
  { icon: '🎥', t: 'דאשקאם', href: '/services/multimedia/dashcam/', d: 'מצלמת דרך עם מצב חנייה.' },
  { icon: '🔊', t: 'מערכות שמע', href: '/services/multimedia/sound-systems/', d: 'רמקולים, סאבוופר ומגבר.' },
  { icon: '⚡', t: 'חשמלאי רכב', href: '/services/electrical/', d: 'דיאגנוסטיקה, מצבר ואלטרנטור.' },
  { icon: '🔗', t: 'ווי גרירה', href: '/services/towing-hitch/', d: 'קבוע, נשלף, חיבור 7/13 פינים.' },
]

const faqs = [
  { q: 'כמה זמן נסיעה מיקנעם אליכם?', a: `יקנעם ויקנעם עילית נמצאות ${area.distance} ק"מ מהסדנה שלנו — כ-25-30 דקות. הדרך עוברת דרך כביש 70 מזרחה לכיוון מגדל העמק ומשם לגלבוע, או ישירות דרך 675. רוב לקוחות יקנעם מביאים בבוקר ומוצאים את הרכב מוכן אחר הצהריים.` },
  { q: 'יקנעם היא עיר הייטק — איזה לקוחות מגיעים אליכם?', a: 'תושבי יקנעם ויקנעם עילית — ובמיוחד עובדי ההייטק שרוצים CarPlay אלחוטי לנסיעות הארוכות לתל אביב. מסך אנדרואיד שהופך את הנסיעה של שעה ליותר נוחה הוא אחד השדרוגים הנפוצים ביותר בקרב לקוחות יקנעם.' },
  { q: 'האם אפשר לקבוע תור בסוף שבוע?', a: 'אנחנו פועלים ימי א׳–ה׳ 08:00–18:00 ושישי 08:00–13:00. לתיאום תור — וואטסאפ הוא הדרך המהירה ביותר.' },
]
---
<BaseLayout title={title} description={description} schema={schema}>
  <nav class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-gray-600">
      <a href="/" class="hover:text-brand-700">בית</a><span class="mx-2">›</span>
      <a href="/areas/" class="hover:text-brand-700">אזורי שירות</a><span class="mx-2">›</span>
      <span class="text-gray-900 font-medium">יקנעם</span>
    </div>
  </nav>

  <section class="bg-gradient-to-bl from-brand-900 to-brand-700 text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="inline-block bg-white/10 rounded-full px-4 py-1 text-sm font-medium mb-4">{area.distance} ק"מ מיקנעם — כ-25 דקות</div>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        מולטימדיה ושירותי רכב<br/><span class="text-accent-500">לתושבי יקנעם</span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        שירות מקצועי ואישי — {area.distance} ק"מ מיקנעם, עם אחריות מלאה על כל עבודה.
      </p>
    </div>
  </section>

  <article class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 prose-content">
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">לתושבי יקנעם ויקנעם עילית</h2>
        <p class="text-gray-700 leading-relaxed text-lg mb-4">
          יקנעם, עם {area.population.toLocaleString()} תושבים ופארק תעשיות מוביל, היא עיר שמייצגת
          את צפון ישראל המודרני. תושביה — בין הייטקיסטים ועד משפחות ותיקות — מחפשים שירות
          רכב מקצועי, יעיל ושקוף.
        </p>
        <p class="text-gray-700 leading-relaxed text-lg">
          ב<strong>אמיר מערכות</strong>, {area.distance} ק"מ מיקנעם, אנחנו נותנים את כל שירותי
          המולטימדיה והרכב עם ניסיון {business.stats.yearsOfExperience}+ שנים ומעל {business.stats.installationsCount.toLocaleString()} התקנות.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">השירותים לתושבי יקנעם</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {services.map(s => (
            <a href={s.href} class="block p-5 bg-white border border-gray-200 rounded-xl hover:border-brand-500 hover:shadow-md transition">
              <div class="text-2xl mb-2">{s.icon}</div>
              <h3 class="font-bold text-gray-900 mb-1">{s.t}</h3>
              <p class="text-sm text-gray-600">{s.d}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="p-5 bg-brand-900 text-white rounded-xl text-center">
            <div class="text-3xl font-bold text-accent-500 mb-1">{business.stats.yearsOfExperience}+</div>
            <div class="text-sm text-blue-200">שנות ניסיון</div>
          </div>
          <div class="p-5 bg-brand-900 text-white rounded-xl text-center">
            <div class="text-3xl font-bold text-accent-500 mb-1">{business.stats.installationsCount.toLocaleString()}+</div>
            <div class="text-sm text-blue-200">התקנות בוצעו</div>
          </div>
          <div class="p-5 bg-brand-900 text-white rounded-xl text-center">
            <div class="text-3xl font-bold text-accent-500 mb-1">{area.distance} ק"מ</div>
            <div class="text-sm text-blue-200">מיקנעם</div>
          </div>
        </div>
      </section>
    </div>
  </article>

  <FAQ items={faqs} title="שאלות נפוצות מתושבי יקנעם" />
  <CTABanner title="תושב יקנעם? {area.distance} דקות נסיעה מפרידות בינכם לבין שירות מקצועי" subtitle="ייעוץ חינמי, הצעת מחיר תוך שעה" />
</BaseLayout>
