---
import BaseLayout from '../../layouts/BaseLayout.astro'
import FAQ from '../../components/FAQ.astro'
import CTABanner from '../../components/CTABanner.astro'
import business from '../../data/business.js'
import Icon from '../../components/Icon.astro'
import { areas } from '../../data/areas.js'

const area = areas.find(a => a.slug === 'beit-shean')
const title = area.metaTitle
const description = area.metaDescription

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'מולטימדיה ושירותי רכב בבית שאן',
  provider: { '@id': `${business.url}#business` },
  areaServed: { '@type': 'City', name: 'בית שאן' },
}

const services = [
  { icon: 'smartphone', t: 'מסכי אנדרואיד', href: '/services/multimedia/android-screens/', d: 'CarPlay ו-Android Auto על מסך 7-10 אינץ׳.' },
  { icon: 'camera', t: 'מצלמות רוורס', href: '/services/multimedia/parking-cameras/', d: 'מצלמה אחורית וחיישני חנייה.' },
  { icon: 'video', t: 'דאשקאם', href: '/services/multimedia/dashcam/', d: 'הגנה ביטוחית בכל נסיעה.' },
  { icon: 'zap', t: 'חשמלאי רכב', href: '/services/electrical/', d: 'דיאגנוסטיקה ותיקון תקלות חשמל.' },
  { icon: 'link', t: 'ווי גרירה', href: '/services/towing-hitch/', d: 'לחקלאים ועמק המעיינות.' },
  { icon: 'snowflake', t: 'מיזוג רכב', href: '/services/ac-repair/', d: 'חיוני בעמק הבקעה החם.' },
]

const faqs = [
  { q: 'כמה זמן נסיעה מבית שאן אליכם?', a: `בית שאן נמצאת ${area.distance} ק"מ מהסדנה שלנו — כ-20-25 דקות נסיעה דרך כביש 71. זהו אחד מהמרחקים הקצרים ביותר מבין ערי האזור.` },
  { q: 'האם אתם מכירים את הצרכים של לקוחות עמק המעיינות?', a: `לקוחות מבית שאן ועמק המעיינות — ${area.population.toLocaleString()} תושבים ועוד רבים מהמושבים הסמוכים — הם חלק קבוע מבסיס הלקוחות שלנו. החקלאות, ציוד השדה ורכבי ה-4x4 של האזור מאפיינים חלק גדול מהעבודה שלנו כאן.` },
  { q: 'האם שווה לנסוע מבית שאן?', a: '20 דקות מבית שאן הן מרחק קצר, ובסוף היום מקבלים עבודה מקצועית עם אחריות. לקוחות שניסו מקומות אחרים ואז הגיעו אלינו — לרוב נשארים. שקיפות ואחריות הם לא ברורים מאליהם.' },
]
---
<BaseLayout title={title} description={description} schema={schema}>
  <nav class="breadcrumb-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-gray-400">
      <a href="/" class="hover:text-white">בית</a><span class="mx-2">›</span>
      <a href="/areas/" class="hover:text-white">אזורי שירות</a><span class="mx-2">›</span>
      <span class="text-white font-medium">בית שאן</span>
    </div>
  </nav>

  <section class="relative bg-[#040912] text-white py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0 tech-grid opacity-30 pointer-events-none" />
    <div class="absolute inset-0 pointer-events-none hero-radial" />
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="inline-block bg-white/10 rounded-full px-4 py-1 text-sm font-medium mb-4">{area.distance} ק"מ מבית שאן — כ-20 דקות</div>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        מולטימדיה ושירותי רכב<br/><span class="text-accent-500">לתושבי בית שאן ועמק המעיינות</span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        מסכים, מצלמות, חשמלאות ומיזוג — {area.distance} ק"מ מבית שאן, עם שירות אישי ואחריות מלאה.
      </p>
    </div>
  </section>

  <article class="py-12 md:py-16 bg-[#060d1e]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 prose-content">
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">לתושבי בית שאן ועמק המעיינות</h2>
        <p class="text-gray-300 leading-relaxed text-lg mb-4">
          בית שאן, שער עמק המעיינות, עם {area.population.toLocaleString()} תושבים ועוד רבים
          מהמושבים הסמוכים — גד, שלוחות, ניר דוד ועוד — היא עיר שמשרתת חקלאים,
          משפחות ותיקות ואנשי עסקים מהאזור.
        </p>
        <p class="text-gray-300 leading-relaxed text-lg">
          ב<strong>אמיר מערכות</strong>, {area.distance} ק"מ בלבד מבית שאן, אנחנו נותנים את כל
          שירותי הרכב עם שקיפות, אחריות, ומחירים ישרים. ניסיון {business.stats.yearsOfExperience}+ שנים
          עם הלקוחות של האזור.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">השירותים לתושבי בית שאן</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {services.map(s => (
            <a href={s.href} class="block p-5 glass-link-card">
              <div class="w-11 h-11 bg-brand-500/15 text-brand-400 rounded-xl flex items-center justify-center mb-3"><Icon name={s} class="w-5 h-5" /></div>
              <h3 class="font-bold text-white mb-1">{s.t}</h3>
              <p class="text-sm text-gray-400">{s.d}</p>
            </a>
          ))}
        </div>
      </section>
    </div>
  </article>

  <FAQ items={faqs} title="שאלות נפוצות מתושבי בית שאן" />
  <CTABanner title="תושב בית שאן? 20 דקות נסיעה בלבד" subtitle="ייעוץ חינמי — שירות מקצועי עם אחריות" />
</BaseLayout>
