---
import BaseLayout from '../../layouts/BaseLayout.astro'
import FAQ from '../../components/FAQ.astro'
import CTABanner from '../../components/CTABanner.astro'
import business from '../../data/business.js'
import { areas } from '../../data/areas.js'

const area = areas.find(a => a.slug === 'megiddo')
const title = area.metaTitle
const description = area.metaDescription

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'מולטימדיה ושירותי רכב במועצה אזורית מגידו',
  provider: { '@id': `${business.url}#business` },
  areaServed: { '@type': 'AdministrativeArea', name: 'מועצה אזורית מגידו' },
}

const services = [
  { icon: '📱', t: 'מסכי אנדרואיד', href: '/services/multimedia/android-screens/', d: 'CarPlay ו-Android Auto — גם לרכבי שטח.' },
  { icon: '📹', t: 'מצלמות רוורס', href: '/services/multimedia/parking-cameras/', d: 'לרכבים גדולים — 360° מומלצת.' },
  { icon: '🔗', t: 'ווי גרירה', href: '/services/towing-hitch/', d: 'לחקלאים — קבוע, נשלף, 7/13 פינים.' },
  { icon: '⚡', t: 'חשמלאי רכב', href: '/services/electrical/', d: 'דיאגנוסטיקה ותיקון לרכבי שטח וחקלאי.' },
  { icon: '🛠️', t: 'מכונאות', href: '/services/general-mechanics/', d: 'טיפולים, בלמים ומתלים.' },
  { icon: '🚛', t: 'תיקון נגררים', href: '/services/trailer-repair/', d: 'נגרר חקלאי — פנסים, חשמל, בלמים.' },
]

const settlements = ['קיבוץ מגידו', 'רמת השופט', 'מדרך עוז', 'גבעת עוז', 'אלוני אבא', 'ג׳ת', 'כפר קרע', 'ערערה']

const faqs = [
  { q: 'אתם קרובים לכל יישובי מועצה אזורית מגידו?', a: `מועצה אזורית מגידו כוללת עשרות יישובים — קיבוצים, מושבים ועיירות. מושב מלאה, הממוקם ${area.distance} ק"מ מהמרכז, נמצא בנגישות סבירה לרוב יישובי המועצה דרך כביש 65 ו-66.` },
  { q: 'הרבה לקוחות ממגידו הם חקלאים — איך זה משפיע על השירות?', a: 'חקלאים הם לקוחות שאנחנו מכירים טוב — פיקאפים, רכבי 4x4, נגררים חקלאיים, ציוד גרירה. אנחנו יודעים שלחקלאי אין זמן לחכות, ומנסים להכניס תיקוני נגרר ווי גרירה בהקדם.' },
  { q: 'האם אתם מתקינים גם ברכבי שטח ורכבי עבודה?', a: 'כן — רכבי שטח (Hilux, Ranger, L200, D-Max), ג׳יפים ורכבי עבודה הם חלק טבעי מהעבודה שלנו. ווי גרירה לרכבי שטח, מסכי CarPlay לפיקאפ, ומצלמת 360° לרכבים גדולים — שירותים שנפוצים בקרב לקוחות מהמועצה.' },
]
---
<BaseLayout title={title} description={description} schema={schema}>
  <nav class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-gray-600">
      <a href="/" class="hover:text-brand-700">בית</a><span class="mx-2">›</span>
      <a href="/areas/" class="hover:text-brand-700">אזורי שירות</a><span class="mx-2">›</span>
      <span class="text-gray-900 font-medium">מועצה אזורית מגידו</span>
    </div>
  </nav>

  <section class="bg-gradient-to-bl from-brand-900 to-brand-700 text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="inline-block bg-white/10 rounded-full px-4 py-1 text-sm font-medium mb-4">{area.distance} ק"מ ממרכז המועצה</div>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        מולטימדיה ושירותי רכב<br/><span class="text-accent-500">למועצה אזורית מגידו</span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        לכל יישובי המועצה — קיבוצים, מושבים וקהילות. ווי גרירה, חשמלאות, מסכים ועוד.
      </p>
    </div>
  </section>

  <article class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 prose-content">
      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">לכל יישובי מגידו — חקלאים, קיבוצניקים ותושבי הקהילה</h2>
        <p class="text-gray-700 leading-relaxed text-lg mb-4">
          מועצה אזורית מגידו, עם {area.population.toLocaleString()} תושבים ועשרות יישובים,
          מאפיינת את הגליל התחתון המסורתי — חקלאות, קיבוצים, ומשפחות שחיות את אורח
          החיים הכפרי. הרכבים כאן עובדים קשה — גוררים, נוסעים בדרכי עפר, ומחייבים שירות
          שמכיר את הצרכים האלו.
        </p>
        <p class="text-gray-700 leading-relaxed text-lg">
          ב<strong>אמיר מערכות</strong>, במושב מלאה, {area.distance} ק"מ מהמרכז, אנחנו
          מכירים את הלקוחות האלו היטב — חקלאים שצריכים ווי גרירה אמין, רכבי שטח
          שדורשים מסך שעומד ברטט ובאבק, ונגררים שצריכים תיקון מהיר.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">השירותים ליישובי מגידו</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {services.map(s => (
            <a href={s.href} class="block p-5 bg-white border border-gray-200 rounded-xl hover:border-brand-500 hover:shadow-md transition">
              <div class="text-2xl mb-2">{s.icon}</div>
              <h3 class="font-bold text-gray-900 mb-1">{s.t}</h3>
              <p class="text-sm text-gray-600">{s.d}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="mb-12 p-6 bg-gray-50 rounded-xl">
        <h2 class="text-xl md:text-2xl font-bold text-gray-900 mb-4">יישובים שאנחנו משרתים</h2>
        <div class="flex flex-wrap gap-2">
          {settlements.map(s => (
            <span class="bg-white border border-gray-200 rounded-full px-3 py-1 text-sm text-gray-700">{s}</span>
          ))}
          <span class="bg-white border border-gray-200 rounded-full px-3 py-1 text-sm text-gray-500">ועוד יישובים רבים...</span>
        </div>
      </section>
    </div>
  </article>

  <FAQ items={faqs} title="שאלות נפוצות מיישובי מגידו" />
  <CTABanner title="מועצה אזורית מגידו — כל יישוב מוזמן" subtitle="ייעוץ חינמי — לחקלאים, קיבוצניקים ותושבי הקהילה" />
</BaseLayout>
