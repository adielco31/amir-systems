---
import BaseLayout from '../layouts/BaseLayout.astro'
import CTABanner from '../components/CTABanner.astro'
import business from '../data/business.js'
import Breadcrumb from '../components/Breadcrumb.astro'
import Icon from '../components/Icon.astro'

const title = 'אודות | אמיר מערכות — מולטימדיה ושירותי רכב בגלבוע'
const description = `אמיר כהן — ${business.stats.yearsOfExperience}+ שנות ניסיון במולטימדיה, חשמלאות ושירותי רכב. מושב מלאה, הגלבוע. שקיפות, אחריות, ומחירים ישרים.`

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'אודות אמיר מערכות',
  description: description,
  url: `${business.url}/about/`,
  mainEntity: { '@id': `${business.url}#business` },
}

const values = [
  {
    icon: 'search',
    iconBg: 'bg-brand-500/15',
    iconColor: 'text-brand-400',
    title: 'שקיפות מחירים',
    body: 'לפני כל עבודה — הצעת מחיר מפורטת. אין הפתעות בסוף. אם המחיר השתנה תוך כדי, אנחנו מסבירים למה.',
  },
  {
    icon: 'shield',
    iconBg: 'bg-emerald-500/15',
    iconColor: 'text-emerald-400',
    title: 'אחריות מלאה',
    body: 'כל התקנת מולטימדיה — אחריות מלאה על העבודה. כל עבודת חשמל ומכניקה — 12 חודשים. אחריות שאפשר לסמוך עליה.',
  },
  {
    icon: 'zap',
    iconBg: 'bg-amber-500/15',
    iconColor: 'text-amber-400',
    title: 'עבודה מהירה',
    body: 'רוב ההתקנות מתבצעות ביום אחד. מביאים בבוקר, לוקחים אחר הצהריים. אם צריך יותר זמן — אומרים מראש.',
  },
  {
    icon: 'users',
    iconBg: 'bg-violet-500/15',
    iconColor: 'text-violet-400',
    title: 'שירות אישי',
    body: 'מדברים ישירות עם אמיר — לא עם קבלן שקיבל את המפתחות שלכם. כל לקוח מקבל ייעוץ ממוקד לרכב הספציפי שלו.',
  },
]

const stats = [
  { value: `${business.stats.yearsOfExperience}+`, label: 'שנות ניסיון בתחום' },
  { value: `${business.stats.installationsCount.toLocaleString()}+`, label: 'התקנות שבוצעו' },
  { value: `${business.stats.rating}`, label: 'דירוג Google' },
]
---
<BaseLayout title={title} description={description} schema={schema}>
  <Breadcrumb items={[{label: 'אודות'}]} />

  <section class="relative bg-[#040912] text-white py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0 tech-grid opacity-30 pointer-events-none" />
    <div class="absolute inset-0 pointer-events-none hero-radial" />
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        אמיר מערכות —<br/><span class="text-accent-500">הסיפור שלנו</span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        {business.stats.yearsOfExperience}+ שנים של התקנות, תיקונים, ולקוחות שחוזרים — ממושב מלאה לכל האזור.
      </p>
    </div>
  </section>

  <article class="py-12 md:py-16 bg-[#060d1e]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <section class="mb-14">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-12">
          {stats.map(s => (
            <div class="p-5 glass-stats text-center">
              <div class="text-3xl font-bold text-accent-500 mb-1">{s.value}</div>
              <div class="text-sm text-blue-200">{s.label}</div>
            </div>
          ))}
        </div>

       
        <div class="prose-content space-y-4">
          <p class="text-gray-300 leading-relaxed text-lg">
           
          </p>
          <p class="text-gray-300 leading-relaxed text-lg">
            הסדנה הוקמה במושב מלאה שבגלבוע — מקום שמאפשר להגיע מעפולה, מגדל העמק,
            נוף הגליל, יקנעם, טבריה, בית שאן ונצרת בנסיעה קצרה יחסית. לא עיר גדולה —
            אבל שירות שלא כל עיר גדולה יכולה להתאים לו.
          </p>
          <p class="text-gray-300 leading-relaxed text-lg">
            עם {business.stats.yearsOfExperience}+ שנות ניסיון ומעל {business.stats.installationsCount.toLocaleString()} התקנות,
            הפילוסופיה נשארת פשוטה: לעשות את העבודה נכון בפעם הראשונה, לתת מחיר שקוף,
            ולעמוד מאחורי כל עבודה עם אחריות אמיתית.
          </p>
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">הערכים שלנו</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {values.map(v => (
            <div class="p-6 glass-section">
              <div class={`w-14 h-14 ${v.iconBg} ${v.iconColor} rounded-xl flex items-center justify-center mb-4`}>
                <Icon name={v.icon} class="w-7 h-7" />
              </div>
              <h3 class="text-lg font-bold text-white mb-2">{v.title}</h3>
              <p class="text-gray-400 leading-relaxed">{v.body}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">מה אנחנו עושים</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {[
            { icon: 'smartphone', iconBg: 'bg-brand-500/15',  iconColor: 'text-brand-400',  title: 'מולטימדיה',          href: '/services/',             desc: 'מסכי אנדרואיד, מצלמות, דאשקאם, מערכות שמע' },
            { icon: 'zap',        iconBg: 'bg-amber-500/15',  iconColor: 'text-amber-400',  title: 'חשמל ודיאגנוסטיקה', href: '/services/electrical/',  desc: 'תיקון תקלות, קודי מנוע, מצבר ואלטרנטור' },
            { icon: 'link',       iconBg: 'bg-violet-500/15', iconColor: 'text-violet-400', title: 'שירותי שטח',          href: '/services/towing-hitch/', desc: 'ווי גרירה, תיקון נגררים, מיזוג ומכונאות' },
          ].map(s => (
            <a href={s.href} class="block p-5 glass-link-card text-center">
              <div class={`w-12 h-12 ${s.iconBg} ${s.iconColor} rounded-xl flex items-center justify-center mx-auto mb-3`}>
                <Icon name={s.icon} class="w-6 h-6" />
              </div>
              <h3 class="font-bold text-white mb-1">{s.title}</h3>
              <p class="text-sm text-gray-400">{s.desc}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="mb-14">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">איפה אנחנו</h2>
        <div class="p-6 glass-section">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <h3 class="font-bold text-white mb-3">כתובת</h3>
              <p class="text-gray-300">{business.address.street}, {business.address.region}</p>
              <p class="text-gray-500 text-sm mt-1">סמוך לצומת גלבוע, כביש 667</p>
            </div>
            <div>
              <h3 class="font-bold text-white mb-3">שעות פעילות</h3>
              <p class="text-gray-300">ראשון–חמישי: 08:00–18:00</p>
              <p class="text-gray-300">שישי: 08:00–13:00</p>
              <p class="text-gray-500 text-sm mt-1">שבת: סגור</p>
            </div>
          </div>
        </div>
      </section>

    </div>
  </article>

  <CTABanner title="מוכנים להכיר?" subtitle="ייעוץ חינמי — נגידו מה מתאים לרכב שלכם בדיוק" />
</BaseLayout>
