---
import BaseLayout from '../layouts/BaseLayout.astro'
import business from '../data/business.js'
import Breadcrumb from '../components/Breadcrumb.astro'
import Icon from '../components/Icon.astro'

const title = 'יצירת קשר | אמיר מערכות'
const description = 'צרו קשר עם אמיר מערכות — וואטסאפ, טלפון או טופס. מושב מלאה, הגלבוע. שעות פעילות: א׳–ה׳ 08:00–18:00, שישי עד 13:00.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'יצירת קשר — אמיר מערכות',
  url: `${business.url}/contact/`,
  mainEntity: { '@id': `${business.url}#business` },
}
---
<BaseLayout title={title} description={description} schema={schema}>
  <Breadcrumb items={[{label: 'יצירת קשר'}]} />

  <section class="relative bg-[#040912] text-white py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0 tech-grid opacity-30 pointer-events-none" />
    <div class="absolute inset-0 pointer-events-none hero-radial" />
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        יצירת קשר
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        שאלה? רוצים לתאם תור? הדרך הכי מהירה — וואטסאפ.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-[#060d1e]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

        <!-- Contact methods -->
        <div>
          <h2 class="text-2xl font-bold text-white mb-6">דרכי התקשרות</h2>

          <div class="space-y-4">
            <a
              href={`https://wa.me/${business.whatsapp}?text=${encodeURIComponent('שלום, אני מעוניין בייעוץ ושאלה על שירות.')}`}
              class="flex items-center gap-4 p-5 bg-green-500/10 border border-green-500/20 rounded-xl hover:bg-green-500/15 transition-all"
            >
              <div class="w-12 h-12 bg-green-500/15 text-green-400 rounded-xl flex items-center justify-center flex-shrink-0"><Icon name="message-circle" class="w-6 h-6" /></div>
              <div>
                <div class="font-bold text-white">וואטסאפ</div>
                <div class="text-gray-400 text-sm">הדרך הכי מהירה — תשובה תוך שעות</div>
                <div class="text-green-400 font-medium mt-1">{business.phone}</div>
              </div>
            </a>

            <a
              href={`tel:${business.phoneClean}`}
              class="flex items-center gap-4 p-5 bg-brand-500/10 border border-brand-500/20 rounded-xl hover:bg-brand-500/15 transition-all"
            >
              <div class="w-12 h-12 bg-brand-500/15 text-brand-400 rounded-xl flex items-center justify-center flex-shrink-0"><Icon name="phone" class="w-6 h-6" /></div>
              <div>
                <div class="font-bold text-white">טלפון</div>
                <div class="text-gray-400 text-sm">א׳–ה׳ 08:00–18:00 | שישי 08:00–13:00</div>
                <div class="text-brand-400 font-medium mt-1">{business.phone}</div>
              </div>
            </a>

            <a
              href={`mailto:${business.email}`}
              class="flex items-center gap-4 p-5 bg-white/[0.04] border border-white/[0.09] rounded-xl hover:bg-white/[0.07] transition-all"
            >
              <div class="w-12 h-12 bg-white/[0.08] text-gray-300 rounded-xl flex items-center justify-center flex-shrink-0"><Icon name="mail" class="w-6 h-6" /></div>
              <div>
                <div class="font-bold text-white">אימייל</div>
                <div class="text-gray-400 text-sm">לפניות שאינן דחופות</div>
                <div class="text-gray-300 font-medium mt-1">{business.email}</div>
              </div>
            </a>
          </div>

          <div class="mt-8 p-5 glass-card">
            <h3 class="font-bold text-white mb-3">שעות פעילות</h3>
            <div class="space-y-1 text-gray-300">
              <div class="flex justify-between">
                <span>ראשון–חמישי</span>
                <span class="font-medium">08:00–18:00</span>
              </div>
              <div class="flex justify-between">
                <span>שישי</span>
                <span class="font-medium">08:00–13:00</span>
              </div>
              <div class="flex justify-between text-gray-400">
                <span>שבת</span>
                <span>סגור</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact form -->
        <div>
          <h2 class="text-2xl font-bold text-white mb-6">שלחו הודעה</h2>
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-4"
          >
            <input type="hidden" name="access_key" value="TODO-WEB3FORMS-KEY" />
            <input type="hidden" name="subject" value="פנייה חדשה מהאתר — אמיר מערכות" />
            <input type="hidden" name="redirect" value={`${business.url}/contact/?sent=1`} />
            <input type="hidden" name="from_name" value="אמיר מערכות — אתר" />

            <div>
              <label for="name" class="block text-sm font-medium text-gray-300 mb-1">שם מלא</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-white/[0.05] border border-white/[0.15] rounded-lg px-4 py-2.5 text-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
                placeholder="ישראל ישראלי"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-gray-300 mb-1">טלפון</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full bg-white/[0.05] border border-white/[0.15] rounded-lg px-4 py-2.5 text-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
                placeholder="050-000-0000"
              />
            </div>

            <div>
              <label for="service" class="block text-sm font-medium text-gray-300 mb-1">שירות מבוקש</label>
              <select
                id="service"
                name="service"
                class="w-full bg-white/[0.05] border border-white/[0.15] rounded-lg px-4 py-2.5 text-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
              >
                <option value="">בחרו שירות (אופציונלי)</option>
                <option>מסך אנדרואיד / CarPlay</option>
                <option>מצלמות חנייה / 360°</option>
                <option>דאשקאם</option>
                <option>מערכת שמע</option>
                <option>ווי גרירה</option>
                <option>חשמלאי רכב / דיאגנוסטיקה</option>
                <option>מיזוג רכב</option>
                <option>מכונאות / טיפול</option>
                <option>תיקון נגרר</option>
                <option>אחר</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-300 mb-1">הודעה</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full bg-white/[0.05] border border-white/[0.15] rounded-lg px-4 py-2.5 text-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none"
                placeholder="ספרו לנו על הרכב שלכם והשירות שאתם מחפשים..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-brand-700 hover:bg-brand-800 text-white font-bold py-3 px-6 rounded-lg transition"
            >
              שלחו הודעה
            </button>

            <p class="text-xs text-gray-500 text-center">
              לתשובה מהירה יותר — כתבו בוואטסאפ
            </p>
          </form>
        </div>
      </div>

      <!-- Address / Map -->
      <div class="mt-12">
        <h2 class="text-2xl font-bold text-white mb-6">איפה אנחנו</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 glass-section">
            <h3 class="font-bold text-white mb-2">כתובת הסדנה</h3>
            <p class="text-gray-300">{business.address.street}</p>
            <p class="text-gray-300">{business.address.region}</p>
            <p class="text-gray-500 text-sm mt-2">
             <br/>
              
            </p>
          </div>
          <div class="p-6 glass-section">
            <h3 class="font-bold text-white mb-3">הדרך אלינו</h3>
            <ul class="space-y-1 text-sm text-gray-300">
              <li>מעפולה: ~15 דקות (כביש 60 ← 667)</li>
              <li>ממגדל העמק: ~20 דקות</li>
              <li>מנוף הגליל / נצרת: ~25 דקות</li>
              <li>מיקנעם: ~25 דקות</li>
              <li>מטבריה: ~35 דקות</li>
              <li>מבית שאן: ~20 דקות</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
