---
import BaseLayout from '../layouts/BaseLayout.astro'
import business from '../data/business.js'

const title = 'יצירת קשר | אמיר מערכות'
const description = 'צרו קשר עם אמיר מערכות — וואטסאפ, טלפון או טופס. מושב מלאה, הגלבוע. שעות פעילות: א׳–ה׳ 08:00–18:00, שישי עד 13:00.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'יצירת קשר — אמיר מערכות',
  url: `${business.url}/contact/`,
  mainEntity: { '@id': `${business.url}#business` },
}
---
<BaseLayout title={title} description={description} schema={schema}>
  <nav class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-gray-600">
      <a href="/" class="hover:text-brand-700">בית</a><span class="mx-2">›</span>
      <span class="text-gray-900 font-medium">יצירת קשר</span>
    </div>
  </nav>

  <section class="bg-gradient-to-bl from-brand-900 to-brand-700 text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        יצירת קשר
      </h1>
      <p class="text-lg md:text-xl text-blue-100 leading-relaxed">
        שאלה? רוצים לתאם תור? הדרך הכי מהירה — וואטסאפ.
      </p>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

        <!-- Contact methods -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">דרכי התקשרות</h2>

          <div class="space-y-4">
            <a
              href={`https://wa.me/${business.whatsapp}?text=${encodeURIComponent('שלום, אני מעוניין בייעוץ ושאלה על שירות.')}`}
              class="flex items-center gap-4 p-5 bg-green-50 border border-green-200 rounded-xl hover:bg-green-100 transition"
            >
              <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center text-white text-2xl flex-shrink-0">💬</div>
              <div>
                <div class="font-bold text-gray-900">וואטסאפ</div>
                <div class="text-gray-600 text-sm">הדרך הכי מהירה — תשובה תוך שעות</div>
                <div class="text-green-700 font-medium mt-1">{business.phone}</div>
              </div>
            </a>

            <a
              href={`tel:${business.phoneClean}`}
              class="flex items-center gap-4 p-5 bg-brand-50 border border-brand-200 rounded-xl hover:bg-brand-100 transition"
            >
              <div class="w-12 h-12 bg-brand-700 rounded-full flex items-center justify-center text-white text-2xl flex-shrink-0">📞</div>
              <div>
                <div class="font-bold text-gray-900">טלפון</div>
                <div class="text-gray-600 text-sm">א׳–ה׳ 08:00–18:00 | שישי 08:00–13:00</div>
                <div class="text-brand-700 font-medium mt-1">{business.phone}</div>
              </div>
            </a>

            <a
              href={`mailto:${business.email}`}
              class="flex items-center gap-4 p-5 bg-gray-50 border border-gray-200 rounded-xl hover:bg-gray-100 transition"
            >
              <div class="w-12 h-12 bg-gray-600 rounded-full flex items-center justify-center text-white text-2xl flex-shrink-0">✉️</div>
              <div>
                <div class="font-bold text-gray-900">אימייל</div>
                <div class="text-gray-600 text-sm">לפניות שאינן דחופות</div>
                <div class="text-gray-700 font-medium mt-1">{business.email}</div>
              </div>
            </a>
          </div>

          <div class="mt-8 p-5 bg-gray-50 rounded-xl border border-gray-200">
            <h3 class="font-bold text-gray-900 mb-3">שעות פעילות</h3>
            <div class="space-y-1 text-gray-700">
              <div class="flex justify-between">
                <span>ראשון–חמישי</span>
                <span class="font-medium">08:00–18:00</span>
              </div>
              <div class="flex justify-between">
                <span>שישי</span>
                <span class="font-medium">08:00–13:00</span>
              </div>
              <div class="flex justify-between text-gray-400">
                <span>שבת</span>
                <span>סגור</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact form -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">שלחו הודעה</h2>
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-4"
          >
            <input type="hidden" name="access_key" value="TODO-WEB3FORMS-KEY" />
            <input type="hidden" name="subject" value="פנייה חדשה מהאתר — אמיר מערכות" />
            <input type="hidden" name="redirect" value={`${business.url}/contact/?sent=1`} />
            <input type="hidden" name="from_name" value="אמיר מערכות — אתר" />

            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">שם מלא</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
                placeholder="ישראל ישראלי"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">טלפון</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
                placeholder="050-000-0000"
              />
            </div>

            <div>
              <label for="service" class="block text-sm font-medium text-gray-700 mb-1">שירות מבוקש</label>
              <select
                id="service"
                name="service"
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent bg-white"
              >
                <option value="">בחרו שירות (אופציונלי)</option>
                <option>מסך אנדרואיד / CarPlay</option>
                <option>מצלמות חנייה / 360°</option>
                <option>דאשקאם</option>
                <option>מערכת שמע</option>
                <option>ווי גרירה</option>
                <option>חשמלאי רכב / דיאגנוסטיקה</option>
                <option>מיזוג רכב</option>
                <option>מכונאות / טיפול</option>
                <option>תיקון נגרר</option>
                <option>אחר</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">הודעה</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none"
                placeholder="ספרו לנו על הרכב שלכם והשירות שאתם מחפשים..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-brand-700 hover:bg-brand-800 text-white font-bold py-3 px-6 rounded-lg transition"
            >
              שלחו הודעה
            </button>

            <p class="text-xs text-gray-500 text-center">
              לתשובה מהירה יותר — כתבו בוואטסאפ
            </p>
          </form>
        </div>
      </div>

      <!-- Address / Map -->
      <div class="mt-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">איפה אנחנו</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 bg-gray-50 rounded-xl border border-gray-200">
            <h3 class="font-bold text-gray-900 mb-2">כתובת הסדנה</h3>
            <p class="text-gray-700">{business.address.street}</p>
            <p class="text-gray-700">{business.address.region}</p>
            <p class="text-gray-500 text-sm mt-2">
              סמוך לצומת גלבוע — כביש 667.<br/>
              כניסה לפי תיאום מראש בלבד.
            </p>
          </div>
          <div class="p-6 bg-gray-50 rounded-xl border border-gray-200">
            <h3 class="font-bold text-gray-900 mb-3">הדרך אלינו</h3>
            <ul class="space-y-1 text-sm text-gray-700">
              <li>מעפולה: ~15 דקות (כביש 60 ← 667)</li>
              <li>ממגדל העמק: ~20 דקות</li>
              <li>מנוף הגליל / נצרת: ~25 דקות</li>
              <li>מיקנעם: ~25 דקות</li>
              <li>מטבריה: ~35 דקות</li>
              <li>מבית שאן: ~20 דקות</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
